<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>New Order - Eggs Ok</title></head>
<body style="
  margin:0;
  padding:30px 16px 50px;
  font-family:'Nunito',Arial,Helvetica,sans-serif;
  background-image: url('https://eggsokpa.com/admin/main-menu/Main-Page/bagroundimage.webp');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
">
<table width="100%" cellpadding="0" cellspacing="0" border="0" >
<tr><td align="center">

<table width="560" cellpadding="0" cellspacing="0" border="0" style="max-width:560px;width:100%;background:#111111;border-radius:22px;overflow:hidden;box-shadow:0 12px 48px rgba(0,0,0,0.45);">

  <!-- ══════ HEADER ══════ -->
  <tr><td style="background:#111111;padding:32px 24px 20px;text-align:center;border-bottom:3px solid #222;">
    <img src="https://fooddeliveryaudit.com/logo.svg" width="180" height="72" alt="Eggs Ok" style="display:block;margin:0 auto;border:0;">
  </td></tr>

  <!-- ══════ HERO ══════ -->
  <tr><td style="padding:20px 20px 4px;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#1a1a1a;border:2px solid #dfdfdfff;border-radius:14px;">
      <tr><td style="padding:28px 20px 24px;text-align:center;">
        <span style="font-size:30px;display:block;margin-bottom:12px;"><img src="https://eggsokpa.com/webicons/order-received.webp" style="width:60px;height:60px;" /></span>
        <h1 style="margin:0 0 6px;font-size:26px;font-weight:900;color:#ffffff;line-height:1.2;">You've Received a New Order!</h1>
        <p style="margin:0;font-size:13px;color:#ffffffff;font-weight:600;letter-spacing:0.3px;">Order received! Let's get it ready for <%= orderType === 'delivery' ? 'delivery' : 'pickup' %>.</p>
      </td></tr>
    </table>
  </td></tr>

  <!-- ══════ ORDER META ══════ -->
  <tr><td style="padding:24px 28px 8px;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <!-- Row 1: Order From | Order Type -->
      <tr>
        <td width="50%" valign="top" style="padding-bottom:18px;">
          <p style="margin:0 0 3px;font-size:13px;font-weight:900;color:#F5C200;letter-spacing:0.5px;">Order From</p>
          <p style="margin:0;font-size:14px;color:#dddddd;font-weight:600;line-height:1.4;"><%= customerName %></p>
        </td>
        <td width="50%" valign="top" style="padding-bottom:18px;">
          <p style="margin:0 0 3px;font-size:13px;font-weight:900;color:#F5C200;letter-spacing:0.5px;">Order Type</p>
          <p style="margin:0;font-size:14px;color:#dddddd;font-weight:600;text-transform:capitalize;"><%= orderType %></p>
        </td>
      </tr>
      <!-- Row 2: Contact | Order Number -->
      <tr>
        <td width="50%" valign="top" style="padding-bottom:18px;">
          <p style="margin:0 0 3px;font-size:13px;font-weight:900;color:#F5C200;letter-spacing:0.5px;">Contact</p>
          <p style="margin:0;font-size:14px;color:#dddddd;font-weight:600;"><%= customerPhone %></p>
        </td>
        <td width="50%" valign="top" style="padding-bottom:18px;">
          <p style="margin:0 0 3px;font-size:13px;font-weight:900;color:#F5C200;letter-spacing:0.5px;">Order Number</p>
          <p style="margin:0;font-size:14px;color:#dddddd;font-weight:600;"><%= orderNumber %></p>
        </td>
      </tr>
      <% if (orderType === 'delivery' && deliveryAddress) { %>
      <!-- Row 3: Deliver To (full width) -->
      <tr>
        <td colspan="2" valign="top">
          <p style="margin:0 0 3px;font-size:13px;font-weight:900;color:#F5C200;letter-spacing:0.5px;">Deliver To</p>
          <p style="margin:0;font-size:14px;color:#dddddd;font-weight:600;line-height:1.4;"><%= deliveryAddress %><% if (deliveryApt) { %><br><%= deliveryApt %><% } %></p>
        </td>
      </tr>
      <% } %>
    </table>
  </td></tr>

  <!-- Divider -->
  <tr><td style="padding:4px 20px 0;"><table width="100%"><tr><td style="height:1px;background:linear-gradient(to right,transparent,#2e2e2e,transparent);"></td></tr></table></td></tr>

  <!-- ══════ ORDER SUMMARY ══════ -->
  <tr><td style="padding:16px 20px 0;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#1a1a1a;border:2px solid #ffffffff;border-radius:14px;overflow:hidden;">

      <!-- Yellow badge -->
      <tr>
        <td style="padding:14px 14px 0;" align="center">
          <table width="50%" align="center" cellpadding="0" cellspacing="0" border="0" style="background:#F5C200;border-radius:50px;">
            <tr>
              <td style="padding:10px 16px 12px;text-align:center;">
                <p style="margin:0;font-size:20px;font-weight:900;color:#111111;line-height:1;">Order Summary</p>
                <p style="margin:3px 0 0;font-size:11px;color:#333333;font-weight:700;">
                  Order Confirmation Number: <%= orderNumber %>
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- Items -->
      <tr><td style="padding:16px 18px 0;">
        <%- itemsHtml %>
      </td></tr>

      <!-- Totals -->
      <tr>
        <td style="padding:8px 18px 18px;" align="right">
          <table width="40%" align="right" cellpadding="0" cellspacing="0" border="0">
            
            <tr>
              <td style="font-size:13px;color:#ffffffff;font-weight:700;padding:5px 0;border-bottom:1px solid #252525;">Subtotal</td>
              <td align="right" style="font-size:13px;color:#ffffffff;font-weight:700;padding:5px 0;border-bottom:1px solid #252525;">$<%= subtotal %></td>
            </tr>

            <tr>
              <td style="font-size:13px;color:#ffffffff;font-weight:700;padding:5px 0;border-bottom:1px solid #252525;">Tax</td>
              <td align="right" style="font-size:13px;color:#ffffffff;font-weight:700;padding:5px 0;border-bottom:1px solid #252525;">$<%= tax %></td>
            </tr>

            <tr>
              <td style="font-size:13px;color:#ffffffff;font-weight:700;padding:5px 0;border-bottom:1px solid #252525;">Tip</td>
              <td align="right" style="font-size:13px;color:#ffffffff;font-weight:700;padding:5px 0;border-bottom:1px solid #252525;">$<%= tip %></td>
            </tr>

            <% if (orderType === 'delivery') { %>
            <tr>
              <td style="font-size:13px;color:#ffffffff;font-weight:700;padding:5px 0;border-bottom:2px solid #F5C200;">Delivery Fee</td>
              <td align="right" style="font-size:13px;color:#ffffffff;font-weight:700;padding:5px 0;border-bottom:2px solid #F5C200;">$<%= deliveryFee %></td>
            </tr>
            <% } %>

            <tr>
              <td style="font-size:16px;font-weight:900;color:#F5C200;padding:10px 0 2px;">Total Paid</td>
              <td align="right" style="font-size:18px;font-weight:900;color:#F5C200;padding:10px 0 2px;">$<%= total %></td>
            </tr>

          </table>
        </td>
      </tr>
        <!-- ══════ BOTTOM CARDS ══════ -->
  <tr><td style="padding:14px 18px 20px;">
<table width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>

    <!-- LEFT -->
    <td width="50%" valign="top" style="padding-right:6px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0"
        style="background:#F5C200;border:1.5px solid #2e2e2e;border-radius:10px;">
        <tr>
          <td style="padding:14px; vertical-align:top; height:100px;">

            <p style="margin:0 0 8px;font-size:13px;font-weight:900;">Order Summary</p>

            <table width="100%">
              <tr><td>Order ID:</td><td>EO-0118</td></tr>
              <tr><td>Order Date:</td><td>15/04/2026</td></tr>
              <tr><td>Item QTY:</td><td>1</td></tr>
              <tr><td>Order Total:</td><td>$20.75</td></tr>
            </table>

          </td>
        </tr>
      </table>
    </td>

    <!-- RIGHT -->
    <td width="50%" valign="top" style="padding-left:6px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0"
        style="background:#F5C200;border:1.5px solid #2e2e2e;border-radius:10px;">
        <tr>
          <td style="padding:14px; vertical-align:top; height:123px;">

            <p style="margin:0 0 8px;font-size:13px;font-weight:900;">Customer Details</p>

            <table width="100%">
              <tr><td>Name:</td><td>rafeeq</td></tr>
              <tr><td>Contact:</td><td>234444444444</td></tr>
              <tr><td>Address:</td><td>Philadelphia, PA, USA</td></tr>
            </table>

          </td>
        </tr>
      </table>
    </td>

  </tr>
</table>
  </td></tr>
    </table>
  </td></tr>



  <!-- ══════ CONCERN ══════ -->
  <tr><td style="padding:28px 24px 22px;text-align:center;border-top:3px solid #1e1e1e;">
    <h2 style="margin:0 0 6px;font-size:24px;font-weight:900;color:#ffffff;line-height:1.2;">Do you have any concern?</h2>
    <p style="margin:0 0 20px;font-size:13px;color:#ffffff;font-weight:600;">Don't hesitate to contact us if you have any problems with your order.</p>
    <table width="340" cellpadding="0" cellspacing="0" border="0" align="center" style="max-width:340px;">
      <tr>
        <td width="48%" style="padding-right:6px;">
          <a href="mailto:eggsok3517@gmail.com" style="text-decoration:none;display:block;">
            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#e63b2e;border-radius:10px;">
              <tr><td style="padding:14px 12px;text-align:center;">
                <span style="font-size:22px;display:block;margin-bottom:4px;"><img src="https://eggsokpa.com/webicons/email.webp" style="width:30px;height:30px;border-radius:50%;" /></span>
                <span style="font-size:14px;font-weight:900;color:#ffffff;display:block;">Email Us</span>
                <span style="font-size:11px;color:#ffffff;font-weight:700;display:block;margin-top:2px;">eggsok3517@gmail.com</span>
              </td></tr>
            </table>
          </a>
        </td>
        <td width="48%" style="padding-left:6px;">
          <a href="tel:+12159489902" style="text-decoration:none;display:block;">
            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#e63b2e;border-radius:10px;">
              <tr><td style="padding:14px 12px;text-align:center;">
                <span style="font-size:22px;display:block;margin-bottom:4px;"><img src="https://eggsokpa.com/webicons/Contact.webp" style="width:30px;height:30px;border-radius:50%;" /></span>
                <span style="font-size:14px;font-weight:900;color:#ffffff;display:block;">Speak To Us</span>
                <span style="font-size:11px;color:#ffffff;font-weight:700;display:block;margin-top:2px;">(215) 948-9902</span>
              </td></tr>
            </table>
          </a>
        </td>
      </tr>
    </table>
  </td></tr>

  <!-- ══════ FOOTER ══════ -->
<!-- ══════ FOOTER ══════ -->
<tr>
  <td style="background:#0d0d0d;padding:12px 18px;">
 <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr><td height="1" style="background:#ffffffff;line-height:1px;font-size:1px;">&nbsp;</td></tr>
    </table>
    <!-- Info row -->
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:8px;">
      <tr>
        <td align="center" style="font-size:11px;color:#ffffff;font-weight:700;line-height:18px;">

          <img src="https://eggsokpa.com/webicons/Location.webp" width="14" height="14" style="vertical-align:middle;"> 
          3517 Lancaster Ave, Philadelphia, PA 19104

          &nbsp;&nbsp;

          <a href="https://www.eggsokphilly.com" style="color: white; text-decoration: none;">
            <img src="https://eggsokpa.com/webicons/Website.webp" width="14" height="14" style="vertical-align:middle;">
            www.eggsokphilly.com
          </a>

          &nbsp;&nbsp;

          <img src="https://eggsokpa.com/webicons/Contact.webp" width="14" height="14" style="vertical-align:middle;">
          (215) 948-9902

        </td>
      </tr>
    </table>

    <!-- Divider -->
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr><td height="1" style="background:#333;line-height:1px;font-size:1px;">&nbsp;</td></tr>
    </table>

    <!-- Hours -->
    <p style="margin:6px 0;text-align:center;font-size:11px;color:#F5C200;font-weight:800;letter-spacing:0.5px;">
      Mon-Fri: 7AM-4PM · Sat-Sun: 8AM-3PM
    </p>

    <!-- Divider -->
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr><td height="1" style="background:#ffffff;line-height:1px;font-size:1px;">&nbsp;</td></tr>
    </table>

    <!-- Social -->
    <table cellpadding="0" cellspacing="0" border="0" align="center" style="margin:8px auto;">
      <tr>
        <td style="font-size:11px;color:#ffffff;font-weight:700;padding-right:10px;">Connect with us on social networks</td>

        <td style="padding:0 4px;">
          <a href="#"><img src="https://eggsokpa.com/webicons/FB.webp" width="22" height="22"></a>
        </td>

        <td style="padding:0 4px;border-radius:50%;">
          <a href="#"><img src="https://eggsokpa.com/webicons/Insta.webp" width="22" height="22"></a>
        </td>

        <td style="padding:0 4px;">
          <a href="#"><img src="https://eggsokpa.com/webicons/tiktok.webp" width="22" height="22"></a>
        </td>

        <td style="padding:0 4px;">
          <a href="#"><img src="https://eggsokpa.com/webicons/googleplus.webp" width="22" height="22"></a>
        </td>

      </tr>
    </table>

    <!-- Divider -->
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr><td height="1" style="background:#ffffff;line-height:1px;font-size:1px;">&nbsp;</td></tr>
    </table>

    <!-- Copyright -->
    <p style="margin:6px 0 0;text-align:center;font-size:11px;color:#ffffff;font-weight:700;">
      &copy; <%= new Date().getFullYear() %> Eggs Ok. All rights reserved.
    </p>

  </td>
</tr>

</table>
</td></tr>
</table>
</body>
</html>
