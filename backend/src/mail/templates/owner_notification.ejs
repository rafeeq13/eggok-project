<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>New Order Alert - Eggs Ok</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap');

    body, table, td, p, h1, h2, span, a {
      font-family: 'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;
    }
    .heading {
      font-family: 'Playfair Display',Georgia,'Times New Roman',serif !important;
    }

    @media only screen and (max-width: 600px) {
      .container { width: 100% !important; max-width: 100% !important; }
      .px-24 { padding-left: 20px !important; padding-right: 20px !important; }
      .hero-title { font-size: 24px !important; }
      .order-total { font-size: 22px !important; }
      .two-col { display: block !important; width: 100% !important; padding: 0 0 14px 0 !important; }
      .cta-btn { padding: 14px 22px !important; font-size: 15px !important; }
      .footer-contact { font-size: 12px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:30px 16px 50px;font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;background:#F8F9FA;color:#4D4D4D;">
<table width="100%" cellpadding="0" cellspacing="0" border="0">
<tr><td align="center">

<table class="container" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;background:#FFFFFF;border:1px solid #E5E5E5;border-radius:14px;overflow:hidden;box-shadow:0 6px 24px rgba(13,13,13,0.06);">

  <!-- ══════ URGENCY BANNER ══════ -->
  <tr>
    <td style="background:#FC0301;padding:14px 20px;text-align:center;">
      <p style="margin:0;font-size:12px;font-weight:700;color:#FFFFFF;letter-spacing:2px;text-transform:uppercase;">
        &#9888; New Order Alert &middot; Action Required
      </p>
    </td>
  </tr>

  <!-- ══════ HEADER ══════ -->
  <tr>
    <td style="background:#FFFFFF;padding:28px 24px 18px;text-align:center;border-bottom:1px solid #E5E5E5;">
      <img src="https://eggsokpa.com/webicons/logo.webp" width="160" height="64" alt="Eggs Ok" style="display:block;margin:0 auto;border:0;">
    </td>
  </tr>

  <!-- ══════ HERO: ORDER # + TOTAL ══════ -->
  <tr>
    <td class="px-24" style="padding:30px 28px 10px;text-align:center;">
      <p style="margin:0 0 8px;font-size:12px;font-weight:700;color:#777777;letter-spacing:2px;text-transform:uppercase;">
        New Order Received
      </p>
      <h1 class="heading hero-title" style="margin:0 0 14px;font-size:28px;font-weight:700;color:#0D0D0D;line-height:1.2;font-family:'Playfair Display',Georgia,'Times New Roman',serif;">
        Order #<%= orderNumber %>
      </h1>
      <table align="center" cellpadding="0" cellspacing="0" border="0" style="margin:0 auto;">
        <tr>
          <td style="background:#FFF8D6;border:1px solid #E3BF22;border-radius:10px;padding:14px 28px;text-align:center;">
            <p style="margin:0 0 4px;font-size:12px;font-weight:700;color:#777777;letter-spacing:1.5px;text-transform:uppercase;">Order Total</p>
            <p class="order-total" style="margin:0;font-size:24px;font-weight:700;color:#0D0D0D;line-height:1;">$<%= total %></p>
          </td>
        </tr>
      </table>
      <p style="margin:16px 0 0;font-size:14px;color:#777777;font-weight:500;">
        Received <%= new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %> &middot; <%= itemCount %> item<%= itemCount > 1 ? 's' : '' %>
      </p>
    </td>
  </tr>

  <!-- ══════ ORDER TYPE BADGE ══════ -->
  <tr>
    <td class="px-24" style="padding:20px 28px 6px;text-align:center;">
      <table align="center" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td style="background:#0D0D0D;border-radius:999px;padding:8px 18px;text-align:center;">
            <span style="font-size:12px;font-weight:700;color:#E3BF22;letter-spacing:1.5px;text-transform:uppercase;">
              <% if (orderType === 'delivery') { %>&#128666; Delivery Order<% } else { %>&#128722; Pickup Order<% } %>
            </span>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- ══════ CUSTOMER QUICK CONTACT ══════ -->
  <tr>
    <td class="px-24" style="padding:18px 28px 6px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F8F9FA;border:1px solid #E5E5E5;border-radius:10px;">
        <tr>
          <td style="padding:18px 20px;">
            <p style="margin:0 0 12px;font-size:12px;font-weight:700;color:#777777;letter-spacing:1.5px;text-transform:uppercase;">
              &#9742; Customer &middot; Quick Contact
            </p>
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td class="two-col" width="40%" valign="top" style="padding:4px 0;">
                  <p style="margin:0;font-size:12px;font-weight:600;color:#777777;">Name</p>
                  <p style="margin:2px 0 0;font-size:15px;font-weight:600;color:#0D0D0D;line-height:1.3;"><%= customerName %></p>
                </td>
                <td class="two-col" width="30%" valign="top" style="padding:4px 0;">
                  <p style="margin:0;font-size:12px;font-weight:600;color:#777777;">Phone</p>
                  <p style="margin:2px 0 0;font-size:15px;font-weight:600;line-height:1.3;">
                    <a href="tel:<%= customerPhone %>" style="color:#0D0D0D;text-decoration:none;"><%= customerPhone %></a>
                  </p>
                </td>
                <td class="two-col" width="30%" valign="top" style="padding:4px 0;">
                  <p style="margin:0;font-size:12px;font-weight:600;color:#777777;">Email</p>
                  <p style="margin:2px 0 0;font-size:14px;font-weight:500;line-height:1.3;word-break:break-all;">
                    <a href="mailto:<%= customerEmail %>" style="color:#0D0D0D;text-decoration:none;"><%= customerEmail %></a>
                  </p>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <% if (orderType === 'delivery' && deliveryAddress) { %>
  <!-- ══════ DELIVERY ADDRESS ══════ -->
  <tr>
    <td class="px-24" style="padding:12px 28px 6px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#FFF8D6;border-left:4px solid #E3BF22;border-radius:8px;">
        <tr>
          <td style="padding:14px 18px;">
            <p style="margin:0 0 4px;font-size:12px;font-weight:700;color:#777777;letter-spacing:1.5px;text-transform:uppercase;">
              &#128205; Deliver To
            </p>
            <p style="margin:0;font-size:15px;font-weight:600;color:#0D0D0D;line-height:1.4;">
              <%= deliveryAddress %><% if (deliveryApt) { %><br><span style="font-weight:500;color:#4D4D4D;"><%= deliveryApt %></span><% } %>
            </p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <% } %>

  <% if (typeof scheduledTime !== 'undefined' && scheduledTime) { %>
  <!-- ══════ SCHEDULED TIME ══════ -->
  <tr>
    <td class="px-24" style="padding:12px 28px 6px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F8F9FA;border:1px solid #E5E5E5;border-radius:8px;">
        <tr>
          <td style="padding:12px 18px;">
            <p style="margin:0 0 4px;font-size:12px;font-weight:700;color:#777777;letter-spacing:1.5px;text-transform:uppercase;">
              &#128336; Scheduled For
            </p>
            <p style="margin:0;font-size:15px;font-weight:600;color:#0D0D0D;line-height:1.4;"><%= scheduledTime %></p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <% } %>

  <!-- ══════ ORDER ITEMS ══════ -->
  <tr>
    <td class="px-24" style="padding:22px 28px 4px;">
      <p style="margin:0 0 12px;font-size:12px;font-weight:700;color:#777777;letter-spacing:1.5px;text-transform:uppercase;">
        Items Ordered
      </p>
      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#FFFFFF;border:1px solid #E5E5E5;border-radius:10px;">
        <tr>
          <td style="padding:14px 18px;color:#4D4D4D;font-size:15px;font-weight:500;line-height:1.5;">
            <%- itemsHtml %>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- ══════ TOTALS ══════ -->
  <tr>
    <td class="px-24" style="padding:16px 28px 6px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td align="right">
            <table width="60%" align="right" cellpadding="0" cellspacing="0" border="0" style="min-width:260px;">

              <tr>
                <td style="font-size:14px;color:#4D4D4D;font-weight:500;padding:8px 0;border-bottom:1px solid #E5E5E5;">Subtotal</td>
                <td align="right" style="font-size:14px;color:#0D0D0D;font-weight:600;padding:8px 0;border-bottom:1px solid #E5E5E5;">$<%= subtotal %></td>
              </tr>

              <tr>
                <td style="font-size:14px;color:#4D4D4D;font-weight:500;padding:8px 0;border-bottom:1px solid #E5E5E5;">Tax</td>
                <td align="right" style="font-size:14px;color:#0D0D0D;font-weight:600;padding:8px 0;border-bottom:1px solid #E5E5E5;">$<%= tax %></td>
              </tr>

              <tr>
                <td style="font-size:14px;color:#4D4D4D;font-weight:500;padding:8px 0;border-bottom:1px solid #E5E5E5;">Tip</td>
                <td align="right" style="font-size:14px;color:#0D0D0D;font-weight:600;padding:8px 0;border-bottom:1px solid #E5E5E5;">$<%= tip %></td>
              </tr>

              <% if (orderType === 'delivery') { %>
              <tr>
                <td style="font-size:14px;color:#4D4D4D;font-weight:500;padding:8px 0;border-bottom:1px solid #E5E5E5;">Delivery Fee</td>
                <td align="right" style="font-size:14px;color:#0D0D0D;font-weight:600;padding:8px 0;border-bottom:1px solid #E5E5E5;">$<%= deliveryFee %></td>
              </tr>
              <% } %>

              <tr>
                <td style="font-size:16px;color:#0D0D0D;font-weight:700;padding:12px 0 2px;border-top:2px solid #E3BF22;">Total</td>
                <td align="right" style="font-size:24px;color:#0D0D0D;font-weight:700;padding:12px 0 2px;border-top:2px solid #E3BF22;">$<%= total %></td>
              </tr>

            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <% if (typeof specialInstructions !== 'undefined' && specialInstructions) { %>
  <!-- ══════ SPECIAL INSTRUCTIONS ══════ -->
  <tr>
    <td class="px-24" style="padding:14px 28px 6px;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#FFF8D6;border-left:4px solid #FC0301;border-radius:8px;">
        <tr>
          <td style="padding:14px 18px;">
            <p style="margin:0 0 6px;font-size:12px;font-weight:700;color:#FC0301;letter-spacing:1.5px;text-transform:uppercase;">
              &#9888; Special Instructions
            </p>
            <p style="margin:0;font-size:15px;font-weight:500;color:#0D0D0D;line-height:1.5;"><%= specialInstructions %></p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <% } %>

  <!-- ══════ CTA BUTTON ══════ -->
  <tr>
    <td class="px-24" style="padding:28px 28px 22px;text-align:center;">
      <table align="center" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td style="background:#E3BF22;border-radius:8px;">
            <a href="https://eggsokpa.com/admin/orders" class="cta-btn" style="display:inline-block;padding:12px 28px;font-size:16px;font-weight:600;color:#0D0D0D;text-decoration:none;font-family:'Geist','Inter',Arial,sans-serif;">
              View in Dashboard &rsaquo;
            </a>
          </td>
        </tr>
      </table>
      <p style="margin:14px 0 0;font-size:13px;color:#777777;font-weight:500;">
        Manage this order, update status, and contact the customer.
      </p>
    </td>
  </tr>

  <!-- ══════ FOOTER ══════ -->
  <tr>
    <td style="background:#F8F9FA;border-top:1px solid #E5E5E5;padding:18px 24px;text-align:center;">
      <p class="footer-contact" style="margin:0 0 6px;font-size:13px;color:#4D4D4D;font-weight:600;">
        Quick Reference:
        <a href="tel:+12159489902" style="color:#0D0D0D;text-decoration:none;font-weight:700;">(215) 948-9902</a>
      </p>
      <p style="margin:0;font-size:11px;color:#777777;font-weight:500;">
        &copy; <%= new Date().getFullYear() %> Eggs Ok &middot; 3517 Lancaster Ave, Philadelphia, PA 19104
      </p>
    </td>
  </tr>

</table>
</td></tr>
</table>
</body>
</html>
