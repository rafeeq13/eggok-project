<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>New Order – Eggs Ok Admin</title>
  <!--[if mso]>
  <noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript>
  <![endif]-->
</head>
<body style="margin:0;padding:0;background-color:#0d0d0d;font-family:Arial,Helvetica,sans-serif;-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#0d0d0d;">
  <tr>
    <td align="center" style="padding:40px 16px;">

      <!-- CARD -->
      <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0"
        style="max-width:600px;width:100%;background-color:#1a1a1a;border-radius:6px;overflow:hidden;border:1px solid #2e2e2e;">

        <!-- TOP YELLOW BAR -->
        <tr>
          <td height="5" style="background-color:#FED800;font-size:0;line-height:0;">&nbsp;</td>
        </tr>

        <!-- HEADER -->
        <tr>
          <td style="padding:32px 40px 28px;background-color:#1a1a1a;border-bottom:1px solid #2e2e2e;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td valign="middle">
                  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:14px;">
                    <tr>
                      <td style="background-color:#FC0301;border-radius:3px;padding:5px 14px;">
                        <span style="font-family:Arial,sans-serif;font-size:10px;font-weight:700;color:#ffffff;letter-spacing:3px;text-transform:uppercase;">&#9679; &nbsp;INCOMING ORDER</span>
                      </td>
                    </tr>
                  </table>
                  <h1 style="margin:0;font-family:Arial,sans-serif;font-size:30px;font-weight:900;color:#ffffff;text-transform:uppercase;line-height:1.15;">
                    New Order <span style="color:#FED800;">Received</span>
                  </h1>
                </td>
                <td valign="middle" align="right" style="padding-left:20px;">
                  <p style="margin:0 0 2px;font-family:Arial,sans-serif;font-size:18px;font-weight:900;color:#FED800;letter-spacing:1px;">EGGS OK</p>
                  <p style="margin:0;font-family:Arial,sans-serif;font-size:10px;color:#555555;letter-spacing:3px;text-transform:uppercase;">Admin Alert</p>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- ORDER # + TOTAL -->
        <tr>
          <td style="padding:0;background-color:#141414;border-bottom:1px solid #2e2e2e;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td width="50%" style="padding:24px 40px;border-right:1px solid #2e2e2e;">
                  <p style="margin:0 0 6px;font-family:Arial,sans-serif;font-size:10px;font-weight:700;letter-spacing:3px;color:#666666;text-transform:uppercase;">Order Number</p>
                  <p style="margin:0;font-family:Arial,sans-serif;font-size:28px;font-weight:900;color:#FED800;">#<%= orderNumber %></p>
                </td>
                <td width="50%" style="padding:24px 40px;">
                  <p style="margin:0 0 6px;font-family:Arial,sans-serif;font-size:10px;font-weight:700;letter-spacing:3px;color:#666666;text-transform:uppercase;">Total Amount</p>
                  <p style="margin:0;font-family:Arial,sans-serif;font-size:28px;font-weight:900;color:#FED800;">$<%= total %></p>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- CUSTOMER + ORDER TYPE -->
        <tr>
          <td style="padding:0;border-bottom:1px solid #2e2e2e;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td width="55%" style="padding:24px 40px;border-right:1px solid #2e2e2e;vertical-align:top;">
                  <p style="margin:0 0 10px;font-family:Arial,sans-serif;font-size:10px;font-weight:700;letter-spacing:3px;color:#FED800;text-transform:uppercase;">Customer</p>
                  <p style="margin:0 0 5px;font-family:Arial,sans-serif;font-size:16px;font-weight:700;color:#ffffff;"><%= customerName %></p>
                  <p style="margin:0 0 4px;font-family:Arial,sans-serif;font-size:13px;color:#aaaaaa;"><%= customerPhone %></p>
                  <p style="margin:0;font-family:Arial,sans-serif;font-size:12px;color:#666666;"><%= customerEmail %></p>
                </td>
                <td width="45%" style="padding:24px 40px;vertical-align:top;">
                  <p style="margin:0 0 10px;font-family:Arial,sans-serif;font-size:10px;font-weight:700;letter-spacing:3px;color:#FED800;text-transform:uppercase;">Order Type</p>
                  <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                      <td style="background-color:#242000;border:1px solid #FED800;border-radius:3px;padding:7px 18px;">
                        <span style="font-family:Arial,sans-serif;font-size:13px;font-weight:700;color:#FED800;letter-spacing:2px;text-transform:uppercase;"><%= orderType.toUpperCase() %></span>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- DELIVERY ADDRESS (conditional) -->
        <% if (orderType === 'delivery') { %>
        <tr>
          <td style="padding:22px 40px;background-color:#141414;border-bottom:1px solid #2e2e2e;">
            <p style="margin:0 0 10px;font-family:Arial,sans-serif;font-size:10px;font-weight:700;letter-spacing:3px;color:#FED800;text-transform:uppercase;">Delivery Address</p>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-left:4px solid #FED800;">
              <tr>
                <td style="padding:10px 18px;">
                  <p style="margin:0;font-family:Arial,sans-serif;font-size:15px;font-weight:600;color:#eeeeee;line-height:1.5;"><%= deliveryAddress %></p>
                </td>
              </tr>
            </table>
          </td>
        </tr>
        <% } %>

        <!-- ITEMS ORDERED -->
        <tr>
          <td style="padding:24px 40px;border-bottom:1px solid #2e2e2e;">
            <p style="margin:0 0 14px;font-family:Arial,sans-serif;font-size:10px;font-weight:700;letter-spacing:3px;color:#FED800;text-transform:uppercase;">Items Ordered</p>
           <div style="color:#ffffff;">
      <%- itemsHtml %>
    </div>
          </td>
        </tr>

        <!-- CTA -->
        <tr>
          <td style="padding:24px 40px;background-color:#141414;border-bottom:1px solid #2e2e2e;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
              style="background-color:#242000;border:1px solid #FED800;border-radius:4px;">
              <tr>
                <td align="center" style="padding:16px 24px;">
                  <p style="margin:0;font-family:Arial,sans-serif;font-size:13px;font-weight:700;color:#FED800;letter-spacing:1px;text-transform:uppercase;">
                    &#9888;&nbsp; Action Required — Log in to confirm this order
                  </p>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td style="padding:20px 40px;background-color:#111111;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td>
                  <p style="margin:0 0 2px;font-family:Arial,sans-serif;font-size:12px;font-weight:700;color:#ffffffff;letter-spacing:2px;text-transform:uppercase;">EGGS OK · Admin System</p>
                  <p style="margin:0;font-family:Arial,sans-serif;font-size:11px;color:#ffffffff;">3517 Lancaster Ave, Philadelphia PA 19104</p>
                </td>
                <td align="right" valign="middle">
                  <p style="margin:0;font-family:Arial,sans-serif;font-size:11px;color:#3a3a3a;letter-spacing:1px;">eggsokphilly.com</p>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- BOTTOM YELLOW BAR -->
        <tr>
          <td height="5" style="background-color:#FED800;font-size:0;line-height:0;">&nbsp;</td>
        </tr>

      </table>

    </td>
  </tr>
</table>

</body>
</html>