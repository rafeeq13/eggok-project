<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>New Order - Eggs Ok</title>
  <!--[if mso]><noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript><![endif]-->
  <style type="text/css">
    /* Google Font Import */
    @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@600;700;800;900&display=swap');

    /* Reset */
    body, table, td, a { -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%; }
    table, td { mso-table-lspace:0pt; mso-table-rspace:0pt; }
    img { -ms-interpolation-mode:bicubic; border:0; outline:none; text-decoration:none; }

    /* Mobile Responsive */
    @media only screen and (max-width: 600px) {
      .email-wrapper { padding:16px 8px 30px !important; }
      .email-container { width:100% !important; max-width:100% !important; border-radius:16px !important; }

      /* Header */
      .header-cell { padding:24px 16px 16px !important; }
      .header-logo { width:140px !important; height:56px !important; }

      /* Hero */
      .hero-outer { padding:14px 14px 4px !important; }
      .hero-inner { padding:22px 16px 20px !important; }
      .hero-icon { width:50px !important; height:50px !important; }
      .hero-title { font-size:22px !important; }
      .hero-subtitle { font-size:12px !important; }

      /* Greeting */
      .greeting-outer { padding:18px 14px 0 !important; }
      .greeting-inner { padding:16px 14px !important; }
      .greeting-name { font-size:18px !important; }
      .greeting-msg { font-size:12px !important; }

      /* Status Tracker */
      .tracker-cell { padding:14px 8px !important; }
      .step-box { width:50px !important; height:60px !important; }
      .step-box td { padding:6px 2px !important; }
      .step-icon { width:26px !important; height:26px !important; }
      .step-label { font-size:8px !important; }
      .arrow-cell { font-size:12px !important; }

      /* CTA Button */
      .cta-cell { padding:14px 20px 0 !important; }
      .cta-btn { padding:12px 30px !important; }
      .cta-text { font-size:9px !important; }

      /* Divider */
      .divider-cell { padding:10px 14px 0 !important; }

      /* Order Summary */
      .summary-outer { padding:12px 14px 0 !important; }
      .summary-badge { width:70% !important; }
      .summary-badge-title { font-size:17px !important; }
      .summary-badge-sub { font-size:10px !important; }
      .items-cell { padding:12px 12px 0 !important; }
      .totals-cell { padding:6px 12px 14px !important; }
      .totals-table { width:55% !important; }

      /* Bottom Cards */
      .bottom-cards-cell { padding:10px 12px 16px !important; }
      .card-left { display:block !important; width:100% !important; padding:0 0 8px 0 !important; }
      .card-right { display:block !important; width:100% !important; padding:0 !important; }
      .card-inner { height:auto !important; min-height:auto !important; padding:12px !important; }
      .card-title { font-size:12px !important; }
      .card-data { font-size:10px !important; }

      /* Concern */
      .concern-cell { padding:22px 16px 18px !important; }
      .concern-title { font-size:20px !important; }
      .concern-subtitle { font-size:12px !important; }
      .concern-buttons { width:100% !important; max-width:100% !important; }
      .concern-btn-left { padding-right:4px !important; }
      .concern-btn-right { padding-left:4px !important; }
      .concern-btn-label { font-size:12px !important; }
      .concern-btn-info { font-size:9px !important; }
      .concern-btn-icon { width:24px !important; height:24px !important; }

      /* Footer */
      .footer-cell { padding:10px 12px !important; }
      .footer-info { font-size:9px !important; line-height:16px !important; }
      .footer-hours { font-size:10px !important; }
      .footer-social-text { font-size:9px !important; padding-right:6px !important; }
      .footer-social-icon { width:18px !important; height:18px !important; }
      .footer-copyright { font-size:10px !important; }
    }

    /* Extra small screens */
    @media only screen and (max-width: 400px) {
      .email-wrapper { padding:10px 4px 20px !important; }
      .hero-title { font-size:19px !important; }
      .hero-subtitle { font-size:11px !important; }
      .greeting-name { font-size:16px !important; }
      .step-box { width:42px !important; height:52px !important; }
      .step-icon { width:22px !important; height:22px !important; }
      .step-label { font-size:7px !important; }
      .arrow-cell { font-size:10px !important; }
      .concern-title { font-size:18px !important; }
      .summary-badge { width:80% !important; }
      .summary-badge-title { font-size:15px !important; }
      .totals-table { width:65% !important; }
      .footer-info { font-size:8px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:30px 16px 50px;font-family:'Nunito',Arial,Helvetica,sans-serif;background-image:url('https://eggsokpa.com/admin/main-menu/Main-Page/bagroundimage.webp');background-size:cover;background-position:center;background-repeat:no-repeat;background-color:#111111;">

<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
<tr><td align="center" class="email-wrapper" style="padding:30px 16px 50px;">

<table width="560" cellpadding="0" cellspacing="0" border="0" class="email-container" style="max-width:560px;width:100%;background:#111111;border-radius:22px;overflow:hidden;box-shadow:0 12px 48px rgba(0,0,0,0.45);">

  <!-- ══════ HEADER ══════ -->
  <tr><td class="header-cell" style="background:#111111;padding:32px 24px 20px;text-align:center;border-bottom:3px solid #222;">
    <img src="https://eggsokpa.com/webicons/logo.svg" class="header-logo" width="180" height="72" alt="Eggs Ok" style="display:block;margin:0 auto;border:0;">
  </td></tr>

  <!-- ══════ HERO ══════ -->
  <tr><td class="hero-outer" style="padding:20px 20px 4px;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#1a1a1a;border:2px solid #dfdfdf;border-radius:14px;">
      <tr><td class="hero-inner" style="padding:28px 20px 24px;text-align:center;">
        <span style="display:block;margin-bottom:12px;"><img src="https://eggsokpa.com/webicons/order-received.webp" class="hero-icon" style="width:60px;height:60px;" alt="Order Confirmed" /></span>
        <h1 class="hero-title" style="margin:0 0 6px;font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:26px;font-weight:900;color:#ffffff;line-height:1.2;">Your Order is Confirmed!</h1>
        <p class="hero-subtitle" style="margin:0;font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:13px;color:#ffffff;font-weight:600;letter-spacing:0.3px;">Thanks for your order. Will be Ready very soon.</p>
      </td></tr>
    </table>
  </td></tr>

  <!-- ══════ GREETING ══════ -->
  <tr><td class="greeting-outer" style="padding:24px 28px 0;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr><td class="greeting-inner" style="padding:20px 24px;">
        <p class="greeting-name" style="margin:0 0 8px;font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:20px;font-weight:900;color:#F5C200;">Hey <%= customerName %>!</p>
        <p class="greeting-msg" style="margin:0;font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:13px;color:#ffffff;font-weight:600;line-height:1.6;">Your order has been received and we're already getting it ready for you. Get ready for something delicious!</p>
      </td></tr>
    </table>
  </td></tr>

  <!-- ══════ ORDER STATUS TRACKER ══════ -->
  <tr>
    <td class="tracker-cell" style="padding:20px;background:#000000;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <!-- STEP 1 (ACTIVE) -->
          <td align="center" width="18%">
            <table class="step-box" width="60" height="70" cellpadding="0" cellspacing="0" style="background:#F5C200;border-radius:10px;">
              <tr>
                <td align="center" valign="middle" style="padding:8px 4px;">
                  <img src="https://eggsokpa.com/webicons/OrderconfirmationBlack.webp" class="step-icon" width="35" height="35" alt="Confirmed" style="display:block;margin:0 auto 4px;">
                  <div class="step-label" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:10px;color:#000000;font-weight:bold;line-height:1.2;text-align:center;">
                    Order<br>Confirmed
                  </div>
                </td>
              </tr>
            </table>
          </td>

          <!-- ARROW -->
          <td align="center" width="1%" class="arrow-cell" style="color:#F5C200;font-size:18px;font-family:Arial,sans-serif;">&raquo;</td>

          <!-- STEP 2 -->
          <td align="center" width="18%">
            <table class="step-box" width="60" height="70" cellpadding="0" cellspacing="0" style="background:#F5E6A0;border-radius:10px;">
              <tr>
                <td align="center" valign="middle" style="padding:8px 4px;">
                  <img src="https://eggsokpa.com/webicons/orderpreparedblack.webp" class="step-icon" width="35" height="35" alt="Prepared" style="display:block;margin:0 auto 4px;">
                  <div class="step-label" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:10px;color:#000000;font-weight:bold;line-height:1.2;text-align:center;">
                    Order<br>Prepared
                  </div>
                </td>
              </tr>
            </table>
          </td>

          <!-- ARROW -->
          <td align="center" width="2%" class="arrow-cell" style="color:#F5C200;font-size:16px;font-family:Arial,sans-serif;">&raquo;</td>

          <!-- STEP 3 -->
          <td align="center" width="18%">
            <table class="step-box" width="60" height="70" cellpadding="0" cellspacing="0" style="background:#F5E6A0;border-radius:10px;">
              <tr>
                <td align="center" valign="middle" style="padding:8px 4px;">
                  <img src="https://eggsokpa.com/webicons/Readyforpickupblack.webp" class="step-icon" width="35" height="35" alt="Picked Up" style="display:block;margin:0 auto 4px;">
                  <div class="step-label" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:10px;color:#000000;font-weight:bold;line-height:1.2;text-align:center;">
                    Rider<br>
                    <%= orderType === 'delivery' ? 'Picked Up' : 'Pickedup' %>
                  </div>
                </td>
              </tr>
            </table>
          </td>

          <!-- ARROW -->
          <td align="center" width="2%" class="arrow-cell" style="color:#F5C200;font-size:16px;font-family:Arial,sans-serif;">&raquo;</td>

          <!-- STEP 4 -->
          <td align="center" width="18%">
            <table class="step-box" width="60" height="70" cellpadding="0" cellspacing="0" style="background:#F5E6A0;border-radius:10px;">
              <tr>
                <td align="center" valign="middle" style="padding:8px 4px;">
                  <img src="https://eggsokpa.com/webicons/onthewayblack.webp" class="step-icon" width="35" height="35" alt="On The Way" style="display:block;margin:0 auto 4px;">
                  <div class="step-label" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:10px;color:#000000;font-weight:bold;line-height:1.2;text-align:center;">
                    On The<br>Way
                  </div>
                </td>
              </tr>
            </table>
          </td>

          <!-- ARROW -->
          <td align="center" width="2%" class="arrow-cell" style="color:#F5C200;font-size:16px;font-family:Arial,sans-serif;">&raquo;</td>

          <!-- STEP 5 -->
          <td align="center" width="18%">
            <table class="step-box" width="60" height="70" cellpadding="0" cellspacing="0" style="background:#F5E6A0;border-radius:10px;">
              <tr>
                <td align="center" valign="middle" style="padding:8px 4px;">
                  <img src="https://eggsokpa.com/webicons/orderdeliveredyellow.webp" class="step-icon" width="35" height="35" alt="Delivered" style="display:block;margin:0 auto 4px;">
                  <div class="step-label" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:10px;color:#000000;font-weight:bold;line-height:1.2;text-align:center;">
                    Order<br>Delivered
                  </div>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- ══════ TRACK ORDER BUTTON ══════ -->
  <tr><td class="cta-cell" style="padding:16px 40px 0;text-align:center;">
    <table cellpadding="0" cellspacing="0" border="0" style="margin:0 auto;">
      <tr><td class="cta-btn" style="background:#e63b2e;border-radius:50px;padding:14px 40px;">
        <a href="<%= trackOrderUrl %>" class="cta-text" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:10px;font-weight:900;color:#ffffff;text-decoration:none;letter-spacing:0.5px;text-transform:uppercase;">Track Your Order</a>
      </td></tr>
    </table>
  </td></tr>

  <!-- ══════ Divider ══════ -->
  <tr><td class="divider-cell" style="padding:12px 20px 0;"><table width="100%" cellpadding="0" cellspacing="0" border="0"><tr><td style="height:1px;background:linear-gradient(to right,transparent,#2e2e2e,transparent);font-size:0;line-height:0;">&nbsp;</td></tr></table></td></tr>

  <!-- ══════ ORDER SUMMARY ══════ -->
  <tr><td class="summary-outer" style="padding:16px 20px 0;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#1a1a1a;border:2px solid #ffffff;border-radius:14px;overflow:hidden;">

      <!-- Yellow badge -->
      <tr>
        <td style="padding:14px 14px 0;" align="center">
          <table class="summary-badge" width="50%" align="center" cellpadding="0" cellspacing="0" border="0" style="background:#F5C200;border-radius:50px;">
            <tr>
              <td style="padding:10px 16px 12px;text-align:center;">
                <p class="summary-badge-title" style="margin:0;font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:20px;font-weight:900;color:#111111;line-height:1;">Order Summary</p>
                <p class="summary-badge-sub" style="margin:3px 0 0;font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:11px;color:#333333;font-weight:700;">
                  Order Confirmation Number: <%= orderNumber %>
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- Items -->
      <tr><td class="items-cell" style="padding:16px 18px 0;">
        <%- itemsHtml %>
      </td></tr>

      <!-- Totals -->
      <tr>
        <td class="totals-cell" style="padding:8px 18px 18px;" align="right">
          <table class="totals-table" width="40%" align="right" cellpadding="0" cellspacing="0" border="0">

            <tr>
              <td style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:13px;color:#ffffff;font-weight:700;padding:5px 0;border-bottom:1px solid #252525;">Subtotal</td>
              <td align="right" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:13px;color:#ffffff;font-weight:700;padding:5px 0;border-bottom:1px solid #252525;">$<%= subtotal %></td>
            </tr>

            <tr>
              <td style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:13px;color:#ffffff;font-weight:700;padding:5px 0;border-bottom:1px solid #252525;">Tax</td>
              <td align="right" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:13px;color:#ffffff;font-weight:700;padding:5px 0;border-bottom:1px solid #252525;">$<%= tax %></td>
            </tr>

            <tr>
              <td style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:13px;color:#ffffff;font-weight:700;padding:5px 0;border-bottom:1px solid #252525;">Tip</td>
              <td align="right" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:13px;color:#ffffff;font-weight:700;padding:5px 0;border-bottom:1px solid #252525;">$<%= tip %></td>
            </tr>

            <% if (orderType === 'delivery') { %>
            <tr>
              <td style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:13px;color:#ffffff;font-weight:700;padding:5px 0;border-bottom:2px solid #F5C200;">Delivery Fee</td>
              <td align="right" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:13px;color:#ffffff;font-weight:700;padding:5px 0;border-bottom:2px solid #F5C200;">$<%= deliveryFee %></td>
            </tr>
            <% } %>

            <tr>
              <td style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:16px;font-weight:900;color:#F5C200;padding:10px 0 2px;">Total Paid</td>
              <td align="right" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:18px;font-weight:900;color:#F5C200;padding:10px 0 2px;">$<%= total %></td>
            </tr>

          </table>
        </td>
      </tr>

      <!-- ══════ BOTTOM CARDS ══════ -->
      <tr><td class="bottom-cards-cell" style="padding:14px 18px 20px;">
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
          <tr>
            <!-- LEFT -->
            <td class="card-left" width="50%" valign="top" style="padding-right:6px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F5C200;border:1.5px solid #2e2e2e;border-radius:10px;">
                <tr>
                  <td class="card-inner" style="padding:14px;vertical-align:top;height:100px;">
                    <p class="card-title" style="margin:0 0 8px;font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:13px;font-weight:900;color:#000000;">Order Summary</p>
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr><td class="card-data" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#000000;padding:2px 0;">Order ID:</td><td class="card-data" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#000000;padding:2px 0;"><%= orderNumber %></td></tr>
                      <tr><td class="card-data" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#000000;padding:2px 0;">Item QTY:</td><td class="card-data" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#000000;padding:2px 0;"><%= itemCount %></td></tr>
                      <tr><td class="card-data" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#000000;padding:2px 0;">Order Total:</td><td class="card-data" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#000000;padding:2px 0;">$<%= total %></td></tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>

            <!-- RIGHT -->
            <td class="card-right" width="50%" valign="top" style="padding-left:6px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F5C200;border:1.5px solid #2e2e2e;border-radius:10px;">
                <tr>
                  <td class="card-inner" style="padding:14px;vertical-align:top;height:100px;">
                    <p class="card-title" style="margin:0 0 8px;font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:13px;font-weight:900;color:#000000;">Customer Details</p>
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr><td class="card-data" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#000000;padding:2px 0;">Name:</td><td class="card-data" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#000000;padding:2px 0;"><%= customerName %></td></tr>
                      <tr><td class="card-data" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#000000;padding:2px 0;">Contact:</td><td class="card-data" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#000000;padding:2px 0;"><%= customerPhone %></td></tr>
                      <% if (orderType === 'delivery' && deliveryAddress) { %>
                      <tr><td class="card-data" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#000000;padding:2px 0;">Address:</td><td class="card-data" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#000000;padding:2px 0;"><%= deliveryAddress %><%= deliveryApt ? ', ' + deliveryApt : '' %></td></tr>
                      <% } %>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td></tr>

    </table>
  </td></tr>

  <!-- ══════ CONCERN ══════ -->
  <tr><td class="concern-cell" style="padding:28px 24px 22px;text-align:center;border-top:3px solid #1e1e1e;">
    <h2 class="concern-title" style="margin:0 0 6px;font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:24px;font-weight:900;color:#ffffff;line-height:1.2;">Do you have any concern?</h2>
    <p class="concern-subtitle" style="margin:0 0 20px;font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:13px;color:#ffffff;font-weight:600;">Don't hesitate to contact us if you have any problems with your order.</p>
    <table class="concern-buttons" width="340" cellpadding="0" cellspacing="0" border="0" align="center" style="max-width:340px;width:100%;">
      <tr>
        <td width="48%" class="concern-btn-left" style="padding-right:6px;">
          <a href="mailto:eggsok3517@gmail.com" style="text-decoration:none;display:block;">
            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#e63b2e;border-radius:10px;">
              <tr><td style="padding:14px 12px;text-align:center;">
                <span style="display:block;margin-bottom:4px;"><img src="https://eggsokpa.com/webicons/email.webp" class="concern-btn-icon" style="width:30px;height:30px;border-radius:50%;" alt="Email" /></span>
                <span class="concern-btn-label" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:14px;font-weight:900;color:#ffffff;display:block;">Email Us</span>
                <span class="concern-btn-info" style="font-family:'Nunito',Arial,Helvetica,sans-serif;font-size:11px;color:#ffffff;font-weight:700;display:block;margin-top:2px;">eggsok3517@gmail.com</span>
              </td></tr>
            </table>
          </a>
        </td>
