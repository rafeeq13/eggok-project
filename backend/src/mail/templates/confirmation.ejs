<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>Order Confirmation - Eggs Ok</title>
  <!--[if mso]><noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript><![endif]-->
  <style type="text/css">
    /* Google Font Import */
    @import url('https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap');

    /* Reset */
    body, table, td, a { -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%; }
    table, td { mso-table-lspace:0pt; mso-table-rspace:0pt; }
    img { -ms-interpolation-mode:bicubic; border:0; outline:none; text-decoration:none; }

    /* Mobile Responsive */
    @media only screen and (max-width: 600px) {
      .email-wrapper { padding:16px 8px 30px !important; }
      .email-container { width:100% !important; max-width:100% !important; border-radius:16px !important; }

      /* Header */
      .header-cell { padding:24px 16px 16px !important; }
      .header-logo { width:140px !important; height:56px !important; }
      .eyebrow-banner { font-size:10px !important; padding:8px 12px !important; letter-spacing:1px !important; }

      /* Hero */
      .hero-outer { padding:20px 14px 4px !important; }
      .hero-inner { padding:24px 16px 20px !important; }
      .hero-icon { width:50px !important; height:50px !important; }
      .hero-title { font-size:24px !important; }
      .hero-subtitle { font-size:14px !important; }

      /* Greeting */
      .greeting-outer { padding:18px 14px 0 !important; }
      .greeting-inner { padding:16px 14px !important; }
      .greeting-name { font-size:20px !important; }
      .greeting-msg { font-size:14px !important; }

      /* Order Number */
      .ordernum-cell { padding:16px 14px 0 !important; }
      .ordernum-inner { padding:18px 14px !important; }
      .ordernum-label { font-size:11px !important; }
      .ordernum-value { font-size:22px !important; }

      /* Status Tracker */
      .tracker-cell { padding:14px 8px !important; }
      .step-box { width:52px !important; height:62px !important; }
      .step-box td { padding:6px 2px !important; }
      .step-icon { width:26px !important; height:26px !important; }
      .step-label { font-size:8px !important; }
      .arrow-cell { font-size:12px !important; }

      /* CTA Button */
      .cta-cell { padding:16px 20px 0 !important; }
      .cta-btn { padding:12px 28px !important; }
      .cta-text { font-size:15px !important; }

      /* Divider */
      .divider-cell { padding:12px 14px 0 !important; }

      /* Order Summary */
      .summary-outer { padding:14px 14px 0 !important; }
      .summary-title { font-size:22px !important; }
      .summary-sub { font-size:12px !important; }
      .items-cell { padding:14px 14px 0 !important; }
      .totals-cell { padding:8px 14px 14px !important; }
      .totals-table { width:100% !important; }

      /* Bottom Cards */
      .bottom-cards-cell { padding:10px 14px 16px !important; }
      .card-left { display:block !important; width:100% !important; padding:0 0 10px 0 !important; }
      .card-right { display:block !important; width:100% !important; padding:0 !important; }
      .card-inner { height:auto !important; min-height:auto !important; padding:14px !important; }
      .card-title { font-size:12px !important; }
      .card-data { font-size:13px !important; }

      /* Concern */
      .concern-cell { padding:24px 16px 20px !important; }
      .concern-title { font-size:22px !important; }
      .concern-subtitle { font-size:14px !important; }
      .concern-buttons { width:100% !important; max-width:100% !important; }
      .concern-btn-left { padding-right:4px !important; }
      .concern-btn-right { padding-left:4px !important; }
      .concern-btn-label { font-size:13px !important; }
      .concern-btn-info { font-size:11px !important; }
      .concern-btn-icon { width:24px !important; height:24px !important; }

      /* Footer */
      .footer-cell { padding:18px 14px !important; }
      .footer-info { font-size:12px !important; line-height:18px !important; }
      .footer-hours { font-size:12px !important; }
      .footer-social-text { font-size:11px !important; padding-right:6px !important; }
      .footer-social-icon { width:22px !important; height:22px !important; }
      .footer-copyright { font-size:11px !important; }
    }

    /* Extra small screens */
    @media only screen and (max-width: 400px) {
      .email-wrapper { padding:10px 4px 20px !important; }
      .hero-title { font-size:20px !important; }
      .hero-subtitle { font-size:13px !important; }
      .greeting-name { font-size:18px !important; }
      .ordernum-value { font-size:19px !important; }
      .step-box { width:44px !important; height:54px !important; }
      .step-icon { width:22px !important; height:22px !important; }
      .step-label { font-size:7px !important; }
      .arrow-cell { font-size:10px !important; }
      .concern-title { font-size:20px !important; }
      .summary-title { font-size:19px !important; }
      .footer-info { font-size:11px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:30px 16px 50px;font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;background-color:#F8F9FA;color:#4D4D4D;">

<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="background-color:#F8F9FA;">
<tr><td align="center" class="email-wrapper" style="padding:30px 16px 50px;">

<table width="600" cellpadding="0" cellspacing="0" border="0" class="email-container" style="max-width:600px;width:100%;background:#FFFFFF;border:1px solid #E5E5E5;border-radius:16px;overflow:hidden;box-shadow:0 8px 32px rgba(13,13,13,0.06);">

  <!-- ══════ HEADER ══════ -->
  <tr><td class="header-cell" style="background:#FFFFFF;padding:32px 24px 20px;text-align:center;border-bottom:1px solid #E5E5E5;">
    <img src="https://eggsokpa.com/webicons/logo.png" class="header-logo" width="150" height="150" alt="Eggs Ok" style="display:block;margin:0 auto 14px;border:0;">
  </td></tr>

  <!-- ══════ ACCENT STRIPE / EYEBROW ══════ -->
  <tr><td style="background:#E3BF22;padding:0;">
    <p class="eyebrow-banner" style="margin:0;padding:10px 16px;font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;font-weight:700;color:#0D0D0D;letter-spacing:1.4px;text-transform:uppercase;text-align:center;">
      Fresh Made To Order &middot; Philadelphia, PA
    </p>
  </td></tr>

  <!-- ══════ HERO / ORDER RECEIVED ══════ -->
  <tr><td class="hero-outer" style="padding:24px 24px 4px;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F8F9FA;border:1px solid #E5E5E5;border-radius:12px;">
      <tr><td class="hero-inner" style="padding:30px 24px 26px;text-align:center;">
        <!-- Green success circle with checkmark -->
        <table cellpadding="0" cellspacing="0" border="0" align="center" style="margin:0 auto 14px;">
          <tr><td class="hero-icon" align="center" valign="middle" width="60" height="60" style="width:60px;height:60px;background:#22C55E;border-radius:50%;text-align:center;vertical-align:middle;">
            <span style="display:inline-block;font-family:Arial,Helvetica,sans-serif;font-size:32px;font-weight:700;color:#FFFFFF;line-height:60px;">&#10003;</span>
          </td></tr>
        </table>
        <h1 class="hero-title" style="margin:0 0 8px;font-family:'Playfair Display',Georgia,'Times New Roman',serif;font-size:28px;font-weight:700;color:#0D0D0D;line-height:1.2;">Order received</h1>
        <p class="hero-subtitle" style="margin:0;font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:16px;font-weight:500;color:#4D4D4D;line-height:1.6;">Thanks for your order. We're already getting it ready for you.</p>
      </td></tr>
    </table>
  </td></tr>

  <!-- ══════ GREETING ══════ -->
  <tr><td class="greeting-outer" style="padding:20px 28px 0;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr><td class="greeting-inner" style="padding:4px 0;">
        <p class="greeting-name" style="margin:0 0 8px;font-family:'Playfair Display',Georgia,'Times New Roman',serif;font-size:24px;font-weight:700;color:#0D0D0D;line-height:1.3;">Hey <%= customerName %>,</p>
        <p class="greeting-msg" style="margin:0;font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:16px;font-weight:500;color:#4D4D4D;line-height:1.6;">Your order has been received and we're getting it ready for you. Get ready for something delicious!</p>
      </td></tr>
    </table>
  </td></tr>

  <!-- ══════ ORDER NUMBER HIGHLIGHT ══════ -->
  <tr><td class="ordernum-cell" style="padding:20px 28px 0;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F8F9FA;border:1px solid #E5E5E5;border-left:4px solid #E3BF22;border-radius:12px;">
      <tr><td class="ordernum-inner" style="padding:20px 24px;">
        <p class="ordernum-label" style="margin:0 0 6px;font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;font-weight:700;color:#777777;letter-spacing:1.2px;text-transform:uppercase;">Order Number</p>
        <p class="ordernum-value" style="margin:0;font-family:'Playfair Display',Georgia,'Times New Roman',serif;font-size:24px;font-weight:700;color:#0D0D0D;line-height:1.2;"><%= orderNumber %></p>
      </td></tr>
    </table>
  </td></tr>

  <!-- ══════ ORDER STATUS TRACKER ══════ -->
  <tr>
    <td class="tracker-cell" style="padding:24px 20px 4px;">
      <p style="margin:0 0 14px;font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;font-weight:700;color:#777777;letter-spacing:1.2px;text-transform:uppercase;text-align:center;">Order Progress</p>
      <table width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <!-- STEP 1 (ACTIVE) -->
          <td align="center" width="18%">
            <table class="step-box" width="62" height="72" cellpadding="0" cellspacing="0" style="background:#E3BF22;border:1px solid #C9A81D;border-radius:10px;">
              <tr>
                <td align="center" valign="middle" style="padding:8px 4px;">
                  <img src="https://eggsokpa.com/webicons/ContactOrderconfirmationBlack.png" class="step-icon" width="32" height="32" alt="Confirmed" style="display:block;margin:0 auto 4px;">
                  <div class="step-label" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:9px;color:#0D0D0D;font-weight:700;line-height:1.2;text-align:center;letter-spacing:0.3px;">
                    Order<br>Confirmed
                  </div>
                </td>
              </tr>
            </table>
          </td>

          <!-- ARROW -->
          <td align="center" width="1%" class="arrow-cell" style="color:#E3BF22;font-size:18px;font-family:Arial,sans-serif;">&raquo;</td>

          <!-- STEP 2 -->
          <td align="center" width="18%">
            <table class="step-box" width="62" height="72" cellpadding="0" cellspacing="0" style="background:#F8F9FA;border:1px solid #E5E5E5;border-radius:10px;">
              <tr>
                <td align="center" valign="middle" style="padding:8px 4px;">
                  <img src="https://eggsokpa.com/webicons/Contactorderpreparedblack.png" class="step-icon" width="32" height="32" alt="Prepared" style="display:block;margin:0 auto 4px;opacity:0.55;">
                  <div class="step-label" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:9px;color:#777777;font-weight:700;line-height:1.2;text-align:center;letter-spacing:0.3px;">
                    Order<br>Prepared
                  </div>
                </td>
              </tr>
            </table>
          </td>

          <!-- ARROW -->
          <td align="center" width="2%" class="arrow-cell" style="color:#E5E5E5;font-size:16px;font-family:Arial,sans-serif;">&raquo;</td>

          <!-- STEP 3 -->
          <td align="center" width="18%">
            <table class="step-box" width="62" height="72" cellpadding="0" cellspacing="0" style="background:#F8F9FA;border:1px solid #E5E5E5;border-radius:10px;">
              <tr>
                <td align="center" valign="middle" style="padding:8px 4px;">
                  <img src="https://eggsokpa.com/webicons/ContactReadyforpickupblack.png" class="step-icon" width="32" height="32" alt="Picked Up" style="display:block;margin:0 auto 4px;opacity:0.55;">
                  <div class="step-label" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:9px;color:#777777;font-weight:700;line-height:1.2;text-align:center;letter-spacing:0.3px;">
                    Rider<br>
                    <%= orderType === 'delivery' ? 'Picked Up' : 'Pickedup' %>
                  </div>
                </td>
              </tr>
            </table>
          </td>

          <!-- ARROW -->
          <td align="center" width="2%" class="arrow-cell" style="color:#E5E5E5;font-size:16px;font-family:Arial,sans-serif;">&raquo;</td>

          <!-- STEP 4 -->
          <td align="center" width="18%">
            <table class="step-box" width="62" height="72" cellpadding="0" cellspacing="0" style="background:#F8F9FA;border:1px solid #E5E5E5;border-radius:10px;">
              <tr>
                <td align="center" valign="middle" style="padding:8px 4px;">
                  <img src="https://eggsokpa.com/webicons/Contactonthewayblack.png" class="step-icon" width="32" height="32" alt="On The Way" style="display:block;margin:0 auto 4px;opacity:0.55;">
                  <div class="step-label" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:9px;color:#777777;font-weight:700;line-height:1.2;text-align:center;letter-spacing:0.3px;">
                    On The<br>Way
                  </div>
                </td>
              </tr>
            </table>
          </td>

          <!-- ARROW -->
          <td align="center" width="2%" class="arrow-cell" style="color:#E5E5E5;font-size:16px;font-family:Arial,sans-serif;">&raquo;</td>

          <!-- STEP 5 -->
          <td align="center" width="18%">
            <table class="step-box" width="62" height="72" cellpadding="0" cellspacing="0" style="background:#F8F9FA;border:1px solid #E5E5E5;border-radius:10px;">
              <tr>
                <td align="center" valign="middle" style="padding:8px 4px;">
                  <img src="https://eggsokpa.com/webicons/Contactorderdeliveredblack.png" class="step-icon" width="32" height="32" alt="Delivered" style="display:block;margin:0 auto 4px;opacity:0.55;">
                  <div class="step-label" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:9px;color:#777777;font-weight:700;line-height:1.2;text-align:center;letter-spacing:0.3px;">
                    Order<br>Delivered
                  </div>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- ══════ TRACK ORDER BUTTON ══════ -->
  <tr><td class="cta-cell" style="padding:20px 40px 4px;text-align:center;">
    <table cellpadding="0" cellspacing="0" border="0" style="margin:0 auto;">
      <tr><td class="cta-btn" style="background:#E3BF22;border-radius:8px;padding:12px 28px;">
        <a href="<%= trackOrderUrl %>" class="cta-text" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:16px;font-weight:600;color:#0D0D0D;text-decoration:none;">Track Your Order &rsaquo;</a>
      </td></tr>
    </table>
  </td></tr>

  <!-- ══════ Divider ══════ -->
  <tr><td class="divider-cell" style="padding:24px 28px 0;"><table width="100%" cellpadding="0" cellspacing="0" border="0"><tr><td style="height:1px;background:#E5E5E5;font-size:0;line-height:0;">&nbsp;</td></tr></table></td></tr>

  <!-- ══════ ORDER SUMMARY ══════ -->
  <tr><td class="summary-outer" style="padding:24px 28px 0;">

    <!-- Summary Title -->
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:16px;">
      <tr>
        <td>
          <p class="summary-sub" style="margin:0 0 4px;font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;font-weight:700;color:#777777;letter-spacing:1.2px;text-transform:uppercase;">Order Summary</p>
          <p class="summary-title" style="margin:0;font-family:'Playfair Display',Georgia,'Times New Roman',serif;font-size:24px;font-weight:700;color:#0D0D0D;line-height:1.2;">Your Items</p>
        </td>
      </tr>
    </table>

    <!-- Items container -->
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#FFFFFF;border:1px solid #E5E5E5;border-radius:12px;overflow:hidden;">

      <!-- Items -->
      <tr><td class="items-cell" style="padding:18px 20px 4px;color:#4D4D4D;font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:16px;font-weight:500;line-height:1.6;">
        <%- itemsHtml %>
      </td></tr>

      <!-- Totals -->
      <tr>
        <td class="totals-cell" style="padding:10px 20px 18px;">
          <table class="totals-table" width="100%" cellpadding="0" cellspacing="0" border="0">

            <tr>
              <td style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:15px;color:#4D4D4D;font-weight:500;padding:8px 0;border-bottom:1px solid #E5E5E5;">Subtotal</td>
              <td align="right" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:15px;color:#0D0D0D;font-weight:600;padding:8px 0;border-bottom:1px solid #E5E5E5;">$<%= subtotal %></td>
            </tr>

            <tr>
              <td style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:15px;color:#4D4D4D;font-weight:500;padding:8px 0;border-bottom:1px solid #E5E5E5;">Tax</td>
              <td align="right" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:15px;color:#0D0D0D;font-weight:600;padding:8px 0;border-bottom:1px solid #E5E5E5;">$<%= tax %></td>
            </tr>

            <tr>
              <td style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:15px;color:#4D4D4D;font-weight:500;padding:8px 0;border-bottom:1px solid #E5E5E5;">Tip</td>
              <td align="right" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:15px;color:#0D0D0D;font-weight:600;padding:8px 0;border-bottom:1px solid #E5E5E5;">$<%= tip %></td>
            </tr>

            <% if (orderType === 'delivery') { %>
            <tr>
              <td style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:15px;color:#4D4D4D;font-weight:500;padding:8px 0;border-bottom:1px solid #E5E5E5;">Delivery Fee</td>
              <td align="right" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:15px;color:#0D0D0D;font-weight:600;padding:8px 0;border-bottom:1px solid #E5E5E5;">$<%= deliveryFee %></td>
            </tr>
            <% } %>

            <tr>
              <td style="font-family:'Playfair Display',Georgia,'Times New Roman',serif;font-size:18px;font-weight:700;color:#0D0D0D;padding:14px 0 2px;">Total Paid</td>
              <td align="right" style="font-family:'Playfair Display',Georgia,'Times New Roman',serif;font-size:20px;font-weight:700;color:#0D0D0D;padding:14px 0 2px;">$<%= total %></td>
            </tr>

          </table>
        </td>
      </tr>

    </table>
  </td></tr>

  <!-- ══════ BOTTOM CARDS ══════ -->
  <tr><td class="bottom-cards-cell" style="padding:18px 28px 8px;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <!-- LEFT -->
        <td class="card-left" width="50%" valign="top" style="padding-right:8px;">
          <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F8F9FA;border:1px solid #E5E5E5;border-radius:12px;">
            <tr>
              <td class="card-inner" style="padding:18px;vertical-align:top;height:140px;">
                <p class="card-title" style="margin:0 0 12px;font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;font-weight:700;color:#777777;letter-spacing:1.2px;text-transform:uppercase;">Order Summary</p>
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr><td class="card-data" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:14px;font-weight:500;color:#777777;padding:3px 0;">Order ID:</td><td align="right" class="card-data" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:14px;font-weight:600;color:#0D0D0D;padding:3px 0;"><%= orderNumber %></td></tr>
                  <tr><td class="card-data" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:14px;font-weight:500;color:#777777;padding:3px 0;">Item QTY:</td><td align="right" class="card-data" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:14px;font-weight:600;color:#0D0D0D;padding:3px 0;"><%= itemCount %></td></tr>
                  <tr><td class="card-data" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:14px;font-weight:500;color:#777777;padding:3px 0;">Order Total:</td><td align="right" class="card-data" style="font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;font-size:14px;font-weight:700;color:#0D0D0D;padding:3px 0;">$<%= total %></td></tr>
                </table>
              </td>
            </tr>
          </table>
        </td>

        <!-- RIGHT -->
        <td class="card-right" width="50%" valign="top" style="padding-left:8px;">
          <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F8F9FA;border:1px solid #E5E5E5;border-radius:12px;">
            <tr>
              <td class="card-inner" style="padding:18px;vertical-align:top;height:140px;">
