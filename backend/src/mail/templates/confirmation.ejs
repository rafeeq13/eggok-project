<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>Order Confirmed - Eggs Ok</title></head>
<body style="margin:0;padding:0;background-color:#1a1a1a;font-family:Arial,Helvetica,sans-serif;">
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#1a1a1a;">
<tr><td align="center" style="padding:30px 16px;">
<table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;background-color:#111111;border-radius:16px;overflow:hidden;border:1px solid #2a2a2a;">

  <!-- HEADER -->
  <tr><td style="background-color:#000000;padding:0;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr><td style="background-color:#FED800;padding:6px 0;text-align:center;">
        <span style="font-size:11px;font-weight:700;color:#000;letter-spacing:2px;text-transform:uppercase;">Fresh Made To Order &middot; Philadelphia, PA</span>
      </td></tr>
      <tr><td style="background-color:#000;padding:28px 40px;text-align:center;">
        <img src="https://fooddeliveryaudit.com/logo.svg" width="120" height="50" alt="Eggs Ok" style="display:block;margin:0 auto 8px;border:0;">
        <p style="margin:0;font-size:12px;color:#888;letter-spacing:3px;text-transform:uppercase;">Breakfast &amp; Lunch</p>
      </td></tr>
    </table>
  </td></tr>

  <!-- GREEN CHECK BANNER -->
  <tr><td style="background-color:#FC0301;padding:16px 40px;text-align:center;">
<span style="font-size:16px;font-weight:900;color:#ffffff;letter-spacing:1px;text-transform:uppercase;">
  <img src="https://cdn.simpleicons.org/ticktick/ffffff" width="16" height="16" alt="check" style="border:0;vertical-align:middle;margin-right:6px;">
  Order Confirmed
</span>
  </td></tr>

  <!-- GREETING -->
  <tr><td style="padding:32px 40px 0;">
    <p style="margin:0 0 12px;font-size:20px;font-weight:800;color:#FEFEFE;">Hey <%= customerName %>! </p>
    <p style="margin:0;font-size:14px;color:#999;line-height:1.7;">Your order has been received and we're already getting it ready for you. Get ready for something delicious!</p>
  </td></tr>

  <!-- ORDER DETAILS -->
  <tr><td style="padding:28px 40px 0;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#1a1a1a;border-radius:12px;border:1px solid #2a2a2a;overflow:hidden;">
      <tr><td style="background:#FED800;padding:10px 20px;">
        <span style="font-size:11px;font-weight:700;color:#000;letter-spacing:1.5px;text-transform:uppercase;">Order Details</span>
      </td></tr>
      <tr><td style="padding:16px 20px;">
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
          <tr><td style="color:#999;font-size:13px;padding:6px 0;">Order Number</td><td align="right" style="color:#FED800;font-size:13px;font-weight:700;">#<%= orderNumber %></td></tr>
          <tr><td style="color:#999;font-size:13px;padding:6px 0;border-top:1px solid #2a2a2a;">Order Type</td><td align="right" style="color:#FEFEFE;font-size:13px;border-top:1px solid #2a2a2a;text-transform:capitalize;"><%= orderType %></td></tr>
          <% if (orderType === 'delivery' && deliveryAddress) { %>
          <tr><td style="color:#999;font-size:13px;padding:6px 0;border-top:1px solid #2a2a2a;">Deliver To</td><td align="right" style="color:#FEFEFE;font-size:13px;border-top:1px solid #2a2a2a;"><%= deliveryAddress %></td></tr>
          <% } %>
        </table>
      </td></tr>
    </table>
  </td></tr>

  <!-- YOUR ITEMS -->
  <tr><td style="padding:20px 40px 0;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#1a1a1a;border-radius:12px;border:1px solid #2a2a2a;overflow:hidden;">
      <tr><td style="background:#FED800;padding:10px 20px;">
        <span style="font-size:11px;font-weight:700;color:#000;letter-spacing:1.5px;text-transform:uppercase;">Your Items</span>
      </td></tr>
      <tr><td style="padding:16px 20px;">
        <div style="color:#FEFEFE;font-size:14px;line-height:2;"><%- itemsHtml %></div>
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:12px;border-top:1px solid #2a2a2a;padding-top:12px;">
          <tr><td style="color:#999;font-size:13px;padding:4px 0;">Subtotal</td><td align="right" style="color:#FED800;font-size:13px;">$<%= subtotal %></td></tr>
          <tr><td style="color:#999;font-size:13px;padding:4px 0;">Tax</td><td align="right" style="color:#FC0301;font-size:13px;">$<%= tax %></td></tr>
          <% if (tip > 0) { %><tr><td style="color:#999;font-size:13px;padding:4px 0;">Tip</td><td align="right" style="color:#FC0301;font-size:13px;">$<%= tip %></td></tr><% } %>
          <% if (deliveryFee > 0) { %><tr><td style="color:#999;font-size:13px;padding:4px 0;">Delivery Fee</td><td align="right" style="color:#FEFEFE;font-size:13px;">$<%= deliveryFee %></td></tr><% } %>
        </table>
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:12px;border-top:1px solid #2a2a2a;padding-top:12px;">
          <tr><td style="color:#FEFEFE;font-size:16px;font-weight:700;">Total</td><td align="right" style="color:#FED800;font-size:18px;font-weight:900;">$<%= total %></td></tr>
        </table>
      </td></tr>
    </table>
  </td></tr>

  <!-- PICKUP/DELIVERY LOCATION (GREEN CARD) -->
  <tr><td style="padding:20px 40px 0;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#0d1a0d;border-radius:12px;border:1px solid #1a3d1a;overflow:hidden;">
      <tr><td style="padding:18px 20px;">
        <p style="margin:0 0 4px;font-size:11px;font-weight:700;color:#3ddc84;letter-spacing:1px;text-transform:uppercase;"><%= orderType === 'delivery' ? 'Delivery' : 'Pickup' %> Location</p>
        <p style="margin:0 0 2px;font-size:16px;font-weight:700;color:#FEFEFE;">3517 Lancaster Ave</p>
        <p style="margin:0 0 2px;font-size:13px;color:#888;">Philadelphia, PA 19104</p>
        <p style="margin:0;font-size:12px;color:#555;">Mon-Fri: 7AM-4PM &middot; Sat-Sun: 8AM-3PM</p>
      </td></tr>
    </table>
  </td></tr>

  <!-- TRACK BUTTON (WHITE) -->
  <tr><td style="padding:28px 40px 0;text-align:center;">
    <table cellpadding="0" cellspacing="0" border="0" style="margin:0 auto;"><tr><td style="background-color:#FED800;border-radius:10px;padding:16px 44px;">
      <a href="<%= trackOrderUrl %>" style="font-size:14px;font-weight:900;color:#000000;text-decoration:none;letter-spacing:0.5px;text-transform:uppercase;">Track Your Order</a>
    </td></tr></table>
  </td></tr>

  <!-- DIVIDER -->
  <tr><td style="padding:28px 40px 0;"><table width="100%" cellpadding="0" cellspacing="0" border="0"><tr><td style="height:1px;background-color:#2a2a2a;">&nbsp;</td></tr></table></td></tr>

  <!-- FOLLOW US -->
  <tr><td style="padding:24px 40px 0;text-align:center;">
    <p style="margin:0 0 16px;font-size:12px;color:#666;letter-spacing:1px;text-transform:uppercase;">Follow Us</p>
    <table cellpadding="0" cellspacing="0" border="0" style="margin:0 auto;"><tr>
      <td style="padding:0 4px;"><table cellpadding="0" cellspacing="0" border="0"><tr><td style="background:#1a1a1a;border:1px solid #FED800;border-radius:6px;padding:8px 14px;"><a href="https://facebook.com/eggsokphilly" style="font-size:11px;font-weight:700;color:#FED800;text-decoration:none;">Facebook</a></td></tr></table></td>
      <td style="padding:0 4px;"><table cellpadding="0" cellspacing="0" border="0"><tr><td style="background:#1a1a1a;border:1px solid #FED800;border-radius:6px;padding:8px 14px;"><a href="https://instagram.com/eggsokphilly" style="font-size:11px;font-weight:700;color:#FED800;text-decoration:none;">Instagram</a></td></tr></table></td>
      <td style="padding:0 4px;"><table cellpadding="0" cellspacing="0" border="0"><tr><td style="background:#1a1a1a;border:1px solid #FED800;border-radius:6px;padding:8px 14px;"><a href="https://tiktok.com/@eggsokphilly" style="font-size:11px;font-weight:700;color:#FED800;text-decoration:none;">TikTok</a></td></tr></table></td>
      <td style="padding:0 4px;"><table cellpadding="0" cellspacing="0" border="0"><tr><td style="background:#1a1a1a;border:1px solid #FED800;border-radius:6px;padding:8px 14px;"><a href="https://g.page/eggsokphilly" style="font-size:11px;font-weight:700;color:#FED800;text-decoration:none;">Google</a></td></tr></table></td>
    </tr></table>
  </td></tr>

  <!-- FOOTER -->
  <tr><td style="padding:28px 40px 0;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#000;border-radius:12px;overflow:hidden;">
      <tr><td style="padding:24px 28px 16px;text-align:center;border-bottom:1px solid #1a1a1a;">
        <img src="https://fooddeliveryaudit.com/logo.svg" width="100" height="42" alt="Eggs Ok" style="display:block;margin:0 auto 4px;border:0;">
        <p style="margin:0;font-size:11px;color:#555;letter-spacing:2px;text-transform:uppercase;">Breakfast &amp; Lunch &middot; Philadelphia</p>
      </td></tr>
      <tr><td style="padding:16px 28px;text-align:center;">
        <p style="margin:0 0 8px;font-size:13px;color:#888;"><img src="https://cdn.simpleicons.org/googlemaps/FEFEFE" width="13" height="13" alt="loc" style="border:0;vertical-align:middle;margin-right:4px;">3517 Lancaster Ave, Philadelphia, PA 19104</p>
        <p style="margin:0 0 8px;font-size:13px;">
<a href="tel:+12159489902" style="color:#FC0301;text-decoration:none;">
  <img src="https://img.icons8.com/ios-filled/50/FC0301/phone.png" width="13" height="13" alt="phone" style="border:0;vertical-align:middle;margin-right:4px;">
  (215) 948-9902
</a>
          <span style="color:#555;"> &middot; </span>
          <a href="https://eggsokphilly.com" style="color:#FED800;text-decoration:none;">eggsokphilly.com</a>
        </p>
        <p style="margin:0 0 16px;font-size:12px;color:#555;border-bottom:1px solid #1a1a1a;padding-bottom:16px;">Mon-Fri: 7AM-4PM &middot; Sat-Sun: 8AM-3PM</p>
        <p style="margin:0;font-size:11px;color:#444;">&copy; <%= new Date().getFullYear() %> Eggs Ok. All rights reserved.</p>
      </td></tr>
      <tr><td style="background:#FED800;padding:8px;text-align:center;">
        <span style="font-size:10px;font-weight:700;color:#000;letter-spacing:1.5px;text-transform:uppercase;">Made with <img src="https://cdn.simpleicons.org/undertale/FC0301" width="11" height="11" alt="love" style="border:0;vertical-align:middle;"> in Philadelphia &middot; Eggs Ok</span>
      </td></tr>
    </table>
  </td></tr>

  <tr><td style="padding:24px;">&nbsp;</td></tr>

</table>
</td></tr>
</table>
</body>
</html>
