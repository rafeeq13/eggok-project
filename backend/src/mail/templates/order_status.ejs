<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title><%= heroTitle %> - Eggs Ok</title>
  <!--[if mso]><noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript><![endif]-->
  <style type="text/css">
    /* Google Font Import */
    @import url('https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap');

    /* Reset */
    body, table, td, a { -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%; }
    table, td { mso-table-lspace:0pt; mso-table-rspace:0pt; }
    img { -ms-interpolation-mode:bicubic; border:0; outline:none; text-decoration:none; }

    /* Mobile Responsive */
    @media only screen and (max-width: 600px) {
      .email-wrapper { padding:16px 8px 30px !important; background:#F8F9FA !important; }
      .email-container { width:100% !important; max-width:100% !important; border-radius:16px !important; }

      /* Header */
      .header-cell { padding:24px 16px 16px !important; }
      .header-logo { width:140px !important; height:56px !important; }

      /* Hero */
      .hero-outer { padding:14px 14px 4px !important; }
      .hero-inner { padding:22px 16px 20px !important; }
      .hero-icon { width:50px !important; height:50px !important; }
      .hero-title { font-size:22px !important; }
      .hero-subtitle { font-size:13px !important; }

      /* Greeting */
      .greeting-outer { padding:18px 14px 0 !important; }
      .greeting-inner { padding:16px 14px !important; }
      .greeting-name { font-size:18px !important; }
      .greeting-msg { font-size:14px !important; }

      /* Status Tracker */
      .tracker-cell { padding:14px 8px !important; }
      .step-box { width:50px !important; height:60px !important; }
      .step-box td { padding:6px 2px !important; }
      .step-icon { width:26px !important; height:26px !important; }
      .step-label { font-size:8px !important; }
      .arrow-cell { font-size:12px !important; }

      /* Cancelled Box */
      .cancelled-outer { padding:14px 8px !important; }

      /* CTA Button */
      .cta-cell { padding:14px 20px 0 !important; }
      .cta-btn { padding:12px 28px !important; }
      .cta-text { font-size:14px !important; }

      /* Driver info */
      .driver-outer { padding:12px 14px 0 !important; }

      /* Divider */
      .divider-cell { padding:10px 14px 0 !important; }

      /* Order Summary */
      .summary-outer { padding:12px 14px 0 !important; }
      .summary-badge { width:85% !important; }
      .summary-badge-title { font-size:17px !important; }
      .summary-badge-sub { font-size:11px !important; }
      .items-cell { padding:12px 12px 0 !important; }
      .totals-cell { padding:6px 12px 14px !important; }
      .totals-table { width:65% !important; }

      /* Bottom Cards */
      .bottom-cards-cell { padding:10px 12px 16px !important; }
      .card-left { display:block !important; width:100% !important; padding:0 0 8px 0 !important; }
      .card-right { display:block !important; width:100% !important; padding:0 !important; }
      .card-inner { height:auto !important; min-height:auto !important; padding:14px !important; }
      .card-title { font-size:12px !important; }
      .card-data { font-size:11px !important; }

      /* Concern */
      .concern-cell { padding:22px 16px 18px !important; }
      .concern-title { font-size:22px !important; }
      .concern-subtitle { font-size:13px !important; }
      .concern-buttons { width:100% !important; max-width:100% !important; }
      .concern-btn-left { padding-right:4px !important; }
      .concern-btn-right { padding-left:4px !important; }
      .concern-btn-label { font-size:13px !important; }
      .concern-btn-info { font-size:10px !important; }
      .concern-btn-icon { width:24px !important; height:24px !important; }

      /* Footer */
      .footer-cell { padding:14px 14px !important; }
      .footer-info { font-size:11px !important; line-height:18px !important; }
      .footer-hours { font-size:11px !important; }
      .footer-social-text { font-size:11px !important; padding-right:6px !important; }
      .footer-social-icon { width:20px !important; height:20px !important; }
      .footer-copyright { font-size:11px !important; }
    }

    /* Extra small screens */
    @media only screen and (max-width: 400px) {
      .email-wrapper { padding:10px 4px 20px !important; }
      .hero-title { font-size:20px !important; }
      .hero-subtitle { font-size:12px !important; }
      .greeting-name { font-size:16px !important; }
      .step-box { width:42px !important; height:52px !important; }
      .step-icon { width:22px !important; height:22px !important; }
      .step-label { font-size:7px !important; }
      .arrow-cell { font-size:10px !important; }
      .concern-title { font-size:20px !important; }
      .summary-badge { width:92% !important; }
      .summary-badge-title { font-size:15px !important; }
      .totals-table { width:75% !important; }
      .footer-info { font-size:10px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:30px 16px 50px;font-family:'Geist','Inter','Helvetica Neue',Helvetica,Arial,sans-serif;background-color:#F8F9FA;color:#4D4D4D;">

<table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="background-color:#F8F9FA;">
<tr><td align="center" class="email-wrapper" style="padding:30px 16px 50px;background-color:#F8F9FA;">

<table width="600" cellpadding="0" cellspacing="0" border="0" class="email-container" style="max-width:600px;width:100%;background:#FFFFFF;border:1px solid #E5E5E5;border-radius:16px;overflow:hidden;box-shadow:0 4px 20px rgba(13,13,13,0.06);">

  <!-- Yellow accent strip -->
  <tr><td style="height:5px;background:#E3BF22;font-size:0;line-height:0;">&nbsp;</td></tr>

  <!-- ══════ HEADER ══════ -->
  <tr><td class="header-cell" style="background:#FFFFFF;padding:32px 24px 22px;text-align:center;border-bottom:1px solid #E5E5E5;">
    <img src="https://eggsokpa.com/webicons/logo.webp" class="header-logo" width="180" height="72" alt="Eggs Ok" style="display:block;margin:0 auto;border:0;">
  </td></tr>

  <!-- ══════ HERO ══════ -->
  <tr><td class="hero-outer" style="padding:24px 24px 4px;background:#FFFFFF;">
    <%
      var heroBg = '#FFFBEB';
      var heroBorder = '#E3BF22';
      var heroBadgeBg = '#E3BF22';
      var heroBadgeText = '#0D0D0D';
      if (typeof isCancelled !== 'undefined' && isCancelled) {
        heroBg = '#FEF2F2';
        heroBorder = '#FC0301';
        heroBadgeBg = '#FC0301';
        heroBadgeText = '#FFFFFF';
      } else if (typeof activeStep !== 'undefined') {
        if (activeStep >= 5) { // delivered / picked_up
          heroBg = '#F0FDF4';
          heroBorder = '#22C55E';
          heroBadgeBg = '#22C55E';
          heroBadgeText = '#FFFFFF';
        } else if (activeStep >= 3) { // picked up / on the way
          heroBg = '#EFF6FF';
          heroBorder = '#3B82F6';
          heroBadgeBg = '#3B82F6';
          heroBadgeText = '#FFFFFF';
        } else if (activeStep >= 2) { // preparing / ready
          heroBg = '#EFF6FF';
          heroBorder = '#3B82F6';
          heroBadgeBg = '#3B82F6';
          heroBadgeText = '#FFFFFF';
        }
      }
    %>
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:<%= heroBg %>;border:1px solid <%= heroBorder %>;border-radius:14px;">
      <tr><td class="hero-inner" style="padding:30px 22px 26px;text-align:center;">
        <span style="display:inline-block;margin-bottom:14px;"><img src="<%= heroIcon %>" class="hero-icon" style="width:60px;height:60px;" alt="Status" /></span>
        <div style="display:inline-block;padding:6px 14px;background:<%= heroBadgeBg %>;color:<%= heroBadgeText %>;border-radius:999px;font-family:'Geist','Inter',Arial,sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:12px;">Order Status</div>
        <h1 class="hero-title" style="margin:0 0 8px;font-family:'Playfair Display',Georgia,'Times New Roman',serif;font-size:28px;font-weight:700;color:#0D0D0D;line-height:1.2;"><%= heroTitle %></h1>
        <p class="hero-subtitle" style="margin:0;font-family:'Geist','Inter',Arial,sans-serif;font-size:15px;color:#4D4D4D;font-weight:500;line-height:1.6;"><%= heroSubtitle %></p>
      </td></tr>
    </table>
  </td></tr>

  <!-- ══════ GREETING ══════ -->
  <tr><td class="greeting-outer" style="padding:24px 28px 0;background:#FFFFFF;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr><td class="greeting-inner" style="padding:16px 0;">
        <p style="margin:0 0 6px;font-family:'Geist','Inter',Arial,sans-serif;font-size:12px;font-weight:700;color:#777777;text-transform:uppercase;letter-spacing:0.8px;">Hello</p>
        <p class="greeting-name" style="margin:0 0 10px;font-family:'Playfair Display',Georgia,serif;font-size:22px;font-weight:700;color:#0D0D0D;">Hey <%= customerName %>!</p>
        <p class="greeting-msg" style="margin:0;font-family:'Geist','Inter',Arial,sans-serif;font-size:16px;color:#4D4D4D;font-weight:500;line-height:1.6;"><%= greetingMessage %></p>
      </td></tr>
    </table>
  </td></tr>

<% if (!isCancelled) { %>
  <!-- ══════ ORDER STATUS TRACKER ══════ -->
  <tr>
    <td class="tracker-cell" style="padding:20px 24px;background:#FFFFFF;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F8F9FA;border:1px solid #E5E5E5;border-radius:12px;">
        <tr><td style="padding:18px 12px;">
          <p style="margin:0 0 14px;font-family:'Geist','Inter',Arial,sans-serif;font-size:12px;font-weight:700;color:#777777;text-transform:uppercase;letter-spacing:0.8px;text-align:center;">Order Progress</p>
          <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
              <!-- STEP 1: Order Confirmed -->
              <td align="center" width="18%">
                <table class="step-box" width="60" height="70" cellpadding="0" cellspacing="0" style="background:<%= activeStep >= 1 ? '#E3BF22' : '#FFFFFF' %>;border:1px solid <%= activeStep >= 1 ? '#E3BF22' : '#E5E5E5' %>;border-radius:10px;">
                  <tr>
                    <td align="center" valign="middle" style="padding:8px 4px;">
                      <img src="https://eggsokpa.com/webicons/OrderconfirmationBlack.webp" class="step-icon" width="32" height="32" alt="Confirmed" style="display:block;margin:0 auto 4px;<%= activeStep >= 1 ? '' : 'opacity:0.55;' %>">
                      <div class="step-label" style="font-family:'Geist','Inter',Arial,sans-serif;font-size:9px;color:<%= activeStep >= 1 ? '#0D0D0D' : '#777777' %>;font-weight:700;line-height:1.2;text-align:center;text-transform:uppercase;letter-spacing:0.3px;">
                        Order<br>Confirmed
                      </div>
                    </td>
                  </tr>
                </table>
              </td>

              <!-- ARROW -->
              <td align="center" width="1%" class="arrow-cell" style="color:<%= activeStep >= 2 ? '#E3BF22' : '#E5E5E5' %>;font-size:18px;font-family:Arial,sans-serif;font-weight:700;">&raquo;</td>

              <!-- STEP 2: Order Prepared -->
              <td align="center" width="18%">
                <table class="step-box" width="60" height="70" cellpadding="0" cellspacing="0" style="background:<%= activeStep >= 2 ? '#E3BF22' : '#FFFFFF' %>;border:1px solid <%= activeStep >= 2 ? '#E3BF22' : '#E5E5E5' %>;border-radius:10px;">
                  <tr>
                    <td align="center" valign="middle" style="padding:8px 4px;">
                      <img src="https://eggsokpa.com/webicons/orderpreparedblack.webp" class="step-icon" width="32" height="32" alt="Prepared" style="display:block;margin:0 auto 4px;<%= activeStep >= 2 ? '' : 'opacity:0.55;' %>">
                      <div class="step-label" style="font-family:'Geist','Inter',Arial,sans-serif;font-size:9px;color:<%= activeStep >= 2 ? '#0D0D0D' : '#777777' %>;font-weight:700;line-height:1.2;text-align:center;text-transform:uppercase;letter-spacing:0.3px;">
                        Order<br>Prepared
                      </div>
                    </td>
                  </tr>
                </table>
              </td>

              <!-- ARROW -->
              <td align="center" width="2%" class="arrow-cell" style="color:<%= activeStep >= 3 ? '#E3BF22' : '#E5E5E5' %>;font-size:16px;font-family:Arial,sans-serif;font-weight:700;">&raquo;</td>

              <!-- STEP 3: Rider Picked Up -->
              <td align="center" width="18%">
                <table class="step-box" width="60" height="70" cellpadding="0" cellspacing="0" style="background:<%= activeStep >= 3 ? '#E3BF22' : '#FFFFFF' %>;border:1px solid <%= activeStep >= 3 ? '#E3BF22' : '#E5E5E5' %>;border-radius:10px;">
                  <tr>
                    <td align="center" valign="middle" style="padding:8px 4px;">
                      <img src="https://eggsokpa.com/webicons/Readyforpickupblack.webp" class="step-icon" width="32" height="32" alt="Picked Up" style="display:block;margin:0 auto 4px;<%= activeStep >= 3 ? '' : 'opacity:0.55;' %>">
                      <div class="step-label" style="font-family:'Geist','Inter',Arial,sans-serif;font-size:9px;color:<%= activeStep >= 3 ? '#0D0D0D' : '#777777' %>;font-weight:700;line-height:1.2;text-align:center;text-transform:uppercase;letter-spacing:0.3px;">
                        Rider<br>Picked Up
                      </div>
                    </td>
                  </tr>
                </table>
              </td>

              <!-- ARROW -->
              <td align="center" width="2%" class="arrow-cell" style="color:<%= activeStep >= 4 ? '#E3BF22' : '#E5E5E5' %>;font-size:16px;font-family:Arial,sans-serif;font-weight:700;">&raquo;</td>

              <!-- STEP 4: On The Way -->
              <td align="center" width="18%">
                <table class="step-box" width="60" height="70" cellpadding="0" cellspacing="0" style="background:<%= activeStep >= 4 ? '#E3BF22' : '#FFFFFF' %>;border:1px solid <%= activeStep >= 4 ? '#E3BF22' : '#E5E5E5' %>;border-radius:10px;">
                  <tr>
                    <td align="center" valign="middle" style="padding:8px 4px;">
                      <img src="https://eggsokpa.com/webicons/onthewayblack.webp" class="step-icon" width="32" height="32" alt="On The Way" style="display:block;margin:0 auto 4px;<%= activeStep >= 4 ? '' : 'opacity:0.55;' %>">
                      <div class="step-label" style="font-family:'Geist','Inter',Arial,sans-serif;font-size:9px;color:<%= activeStep >= 4 ? '#0D0D0D' : '#777777' %>;font-weight:700;line-height:1.2;text-align:center;text-transform:uppercase;letter-spacing:0.3px;">
                        On The<br>Way
                      </div>
                    </td>
                  </tr>
                </table>
              </td>

              <!-- ARROW -->
              <td align="center" width="2%" class="arrow-cell" style="color:<%= activeStep >= 5 ? '#22C55E' : '#E5E5E5' %>;font-size:16px;font-family:Arial,sans-serif;font-weight:700;">&raquo;</td>

              <!-- STEP 5: Order Delivered -->
              <td align="center" width="18%">
                <table class="step-box" width="60" height="70" cellpadding="0" cellspacing="0" style="background:<%= activeStep >= 5 ? '#22C55E' : '#FFFFFF' %>;border:1px solid <%= activeStep >= 5 ? '#22C55E' : '#E5E5E5' %>;border-radius:10px;">
                  <tr>
                    <td align="center" valign="middle" style="padding:8px 4px;">
                      <img src="https://eggsokpa.com/webicons/orderdeliveredyellow.webp" class="step-icon" width="32" height="32" alt="Delivered" style="display:block;margin:0 auto 4px;<%= activeStep >= 5 ? '' : 'opacity:0.55;' %>">
                      <div class="step-label" style="font-family:'Geist','Inter',Arial,sans-serif;font-size:9px;color:<%= activeStep >= 5 ? '#FFFFFF' : '#777777' %>;font-weight:700;line-height:1.2;text-align:center;text-transform:uppercase;letter-spacing:0.3px;">
                        Order<br>Delivered
                      </div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td></tr>
      </table>
    </td>
  </tr>
<% } else { %>
  <!-- ══════ CANCELLED STATUS ══════ -->
  <tr>
    <td class="cancelled-outer" style="padding:20px 24px;background:#FFFFFF;">
      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#FEF2F2;border:1px solid #FC0301;border-radius:12px;">
        <tr><td style="padding:22px 20px;text-align:center;">
          <div style="display:inline-block;padding:6px 14px;background:#FC0301;color:#FFFFFF;border-radius:999px;font-family:'Geist','Inter',Arial,sans-serif;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:8px;">Order Cancelled</div>
          <p style="margin:6px 0 0;font-family:'Geist','Inter',Arial,sans-serif;font-size:14px;color:#4D4D4D;font-weight:500;line-height:1.6;">This order has been cancelled. If you have any questions, please contact us.</p>
        </td></tr>
      </table>
    </td>
  </tr>
<% } %>

  <!-- ══════ CTA BUTTON ══════ -->
  <tr><td class="cta-cell" style="padding:20px 40px 4px;text-align:center;background:#FFFFFF;">
    <table cellpadding="0" cellspacing="0" border="0" style="margin:0 auto;">
      <tr><td class="cta-btn" style="background:#E3BF22;border-radius:8px;padding:12px 28px;text-align:center;">
        <a href="<%= ctaUrl %>" class="cta-text" style="font-family:'Geist','Inter',Arial,sans-serif;font-size:16px;font-weight:600;color:#0D0D0D;text-decoration:none;letter-spacing:0.2px;"><%= ctaText %> &rsaquo;</a>
      </td></tr>
      <% if (showReviewStars) { %>
      <tr><td style="padding-top:10px;text-align:center;font-size:18px;color:#E3BF22;letter-spacing:3px;">&#9733;&#9733;&#9733;&#9733;&#9733;</td></tr>
      <% } %>
    </table>
  </td></tr>

<% if (driverName) { %>
  <!-- ══════ DRIVER INFO ══════ -->
  <tr><td class="driver-outer" style="padding:20px 24px 0;background:#FFFFFF;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#EFF6FF;border:1px solid #3B82F6;border-radius:12px;overflow:hidden;">
      <tr><td style="padding:18px 20px;text-align:center;">
        <p style="margin:0 0 4px;font-family:'Geist','Inter',Arial,sans-serif;font-size:12px;font-weight:700;color:#777777;text-transform:uppercase;letter-spacing:0.8px;">Your Driver</p>
        <p style="margin:0;font-family:'Playfair Display',Georgia,serif;font-size:18px;font-weight:700;color:#0D0D0D;"><%= driverName %></p>
        <% if (driverEta) { %>
        <p style="margin:6px 0 0;font-family:'Geist','Inter',Arial,sans-serif;font-size:14px;font-weight:500;color:#4D4D4D;">Estimated Arrival: <strong style="color:#3B82F6;"><%= driverEta %></strong></p>
        <% } %>
      </td></tr>
    </table>
  </td></tr>
<% } %>

  <!-- ══════ Divider ══════ -->
  <tr><td class="divider-cell" style="padding:20px 24px 0;background:#FFFFFF;"><table width="100%" cellpadding="0" cellspacing="0" border="0"><tr><td style="height:1px;background:#E5E5E5;font-size:0;line-height:0;">&nbsp;</td></tr></table></td></tr>

  <!-- ══════ ORDER SUMMARY ══════ -->
  <tr><td class="summary-outer" style="padding:20px 24px 0;background:#FFFFFF;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F8F9FA;border:1px solid #E5E5E5;border-radius:14px;overflow:hidden;">

      <!-- Yellow badge -->
      <tr>
        <td style="padding:18px 14px 4px;" align="center">
          <table class="summary-badge" width="70%" align="center" cellpadding="0" cellspacing="0" border="0" style="background:#E3BF22;border-radius:999px;">
            <tr>
              <td style="padding:10px 16px 12px;text-align:center;">
                <p class="summary-badge-title" style="margin:0;font-family:'Playfair Display',Georgia,serif;font-size:20px;font-weight:700;color:#0D0D0D;line-height:1.1;">Order Summary</p>
                <p class="summary-badge-sub" style="margin:3px 0 0;font-family:'Geist','Inter',Arial,sans-serif;font-size:12px;color:#0D0D0D;font-weight:600;">
                  Confirmation #: <%= orderNumber %>
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- Items -->
      <tr><td class="items-cell" style="padding:18px 20px 0;">
        <%- itemsHtml %>
      </td></tr>

      <!-- Totals -->
      <tr>
        <td class="totals-cell" style="padding:8px 20px 20px;" align="right">
          <table class="totals-table" width="50%" align="right" cellpadding="0" cellspacing="0" border="0">

            <tr>
              <td style="font-family:'Geist','Inter',Arial,sans-serif;font-size:14px;color:#4D4D4D;font-weight:500;padding:6px 0;border-bottom:1px solid #E5E5E5;">Subtotal</td>
              <td align="right" style="font-family:'Geist','Inter',Arial,sans-serif;font-size:14px;color:#0D0D0D;font-weight:600;padding:6px 0;border-bottom:1px solid #E5E5E5;">$<%= subtotal %></td>
            </tr>

            <tr>
              <td style="font-family:'Geist','Inter',Arial,sans-serif;font-size:14px;color:#4D4D4D;font-weight:500;padding:6px 0;border-bottom:1px solid #E5E5E5;">Tax</td>
              <td align="right" style="font-family:'Geist','Inter',Arial,sans-serif;font-size:14px;color:#0D0D0D;font-weight:600;padding:6px 0;border-bottom:1px solid #E5E5E5;">$<%= tax %></td>
            </tr>

            <tr>
              <td style="font-family:'Geist','Inter',Arial,sans-serif;font-size:14px;color:#4D4D4D;font-weight:500;padding:6px 0;border-bottom:1px solid #E5E5E5;">Tip</td>
              <td align="right" style="font-family:'Geist','Inter',Arial,sans-serif;font-size:14px;color:#0D0D0D;font-weight:600;padding:6px 0;border-bottom:1px solid #E5E5E5;">$<%= tip %></td>
            </tr>

            <% if (orderType === 'delivery') { %>
            <tr>
              <td style="font-family:'Geist','Inter',Arial,sans-serif;font-size:14px;color:#4D4D4D;font-weight:500;padding:6px 0;border-bottom:2px solid #E3BF22;">Delivery Fee</td>
              <td align="right" style="font-family:'Geist','Inter',Arial,sans-serif;font-size:14px;color:#0D0D0D;font-weight:600;padding:6px 0;border-bottom:2px solid #E3BF22;">$<%= deliveryFee %></td>
            </tr>
            <% } %>

            <tr>
              <td style="font-family:'Playfair Display',Georgia,serif;font-size:16px;font-weight:700;color:#0D0D0D;padding:12px 0 2px;">Total Paid</td>
              <td align="right" style="font-family:'Playfair Display',Georgia,serif;font-size:20px;font-weight:700;color:#0D0D0D;padding:12px 0 2px;">$<%= total %></td>
